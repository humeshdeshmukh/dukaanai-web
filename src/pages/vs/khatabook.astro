---
import { site } from "../../data/site";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { Check, X } from "@lucide/astro";

const title = "Dukaan AI vs Khatabook 2026 — Which is the Better Kirana App?";
const description = "Comparing Dukaan AI vs Khatabook for kirana stores. Dukaan AI offers voice billing in 24 languages, AI bill scanner, GST invoices, and 100% offline mode — all free. See the full comparison.";

const faqs = [
  {
    question: "Is Dukaan AI better than Khatabook for kirana stores?",
    answer: "Yes, Dukaan AI is better for kirana stores because it offers voice billing in 24 Indian languages, an AI bill scanner for supplier invoices, GST invoice generation, and a parchi scanner — features not available in Khatabook. Khatabook is primarily a credit ledger app. Dukaan AI is a complete free shop management solution for kirana retailers."
  },
  {
    question: "What can Dukaan AI do that Khatabook cannot?",
    answer: "Dukaan AI offers voice billing (speak to create bills), an AI-powered OCR bill scanner for supplier invoices, GST invoice generation, inventory tracking, wholesale order management, and a parchi scanner for handwritten customer lists. Khatabook focuses only on digital ledger management and does not offer voice billing or bill scanning."
  },
  {
    question: "Is Dukaan AI free like Khatabook?",
    answer: "Yes, Dukaan AI is completely free on Android with no subscription or trial limitations. All core features — voice billing, digital khata, udhaar tracking, GST invoices, and AI bill scanner — are available at zero cost. Unlike some Khatabook features that require a premium plan, Dukaan AI has no paid tiers."
  },
  {
    question: "Does Dukaan AI work offline like Khatabook?",
    answer: "Yes, Dukaan AI works 100% offline. All khata entries, billing records, and inventory data are stored on your phone. Dukaan AI also supports offline voice billing for 880+ kirana items — a feature Khatabook does not offer. Data syncs to the cloud automatically when internet is available."
  },
  {
    question: "Can I switch from Khatabook to Dukaan AI?",
    answer: "Yes, switching from Khatabook to Dukaan AI is simple. You can start by entering the opening balance for each customer directly in the Smart Khata section. Dukaan AI stores all your customer data securely, and you can export your records at any time. Most shopkeepers switch within 10 minutes."
  }
];

const rows = [
  { feature: "Voice Billing (Hindi & Regional)", dukaan: "✅ 24 languages", other: "❌ Not available", dukaanWin: true },
  { feature: "Digital Khata / Udhaar Tracking", dukaan: "✅ Included", other: "✅ Core feature", dukaanWin: null },
  { feature: "AI Bill Scanner (OCR)", dukaan: "✅ Scan supplier bills", other: "❌ Not available", dukaanWin: true },
  { feature: "GST Invoice Generation", dukaan: "✅ Auto GST slabs", other: "❌ Limited", dukaanWin: true },
  { feature: "Parchi / Handwritten List Scanner", dukaan: "✅ Included", other: "❌ Not available", dukaanWin: true },
  { feature: "Inventory Management", dukaan: "✅ Real-time", other: "❌ Not available", dukaanWin: true },
  { feature: "WhatsApp Bill & Reminder Sharing", dukaan: "✅ One-tap share", other: "✅ Available", dukaanWin: null },
  { feature: "100% Offline Mode", dukaan: "✅ Full offline", other: "✅ Partial", dukaanWin: true },
  { feature: "Voice Billing Offline", dukaan: "✅ 880+ items offline", other: "❌ Not available", dukaanWin: true },
  { feature: "Completely Free Forever", dukaan: "✅ No paid tiers", other: "⚠️ Premium features paid", dukaanWin: true },
  { feature: "Android App", dukaan: "✅ Native Android", other: "✅ Available", dukaanWin: null },
  { feature: "Indian Language Support", dukaan: "✅ 24 languages", other: "⚠️ Limited", dukaanWin: true }
];
---

<BaseLayout title={title} description={description} faqs={faqs}>
  <SiteHeader />

  <main>
    <!-- Hero -->
    <section class="section-shell pb-16 pt-8 sm:pb-24 sm:pt-14">
      <div class="relative overflow-hidden rounded-[42px] border border-white/55 bg-gradient-to-br from-forest-950 via-forest-900 to-forest-800 px-5 py-12 text-center text-white shadow-2xl sm:px-7 lg:px-10">
        <div class="pointer-events-none absolute -left-20 -top-20 h-64 w-64 rounded-full bg-gold-400/20 blur-3xl"></div>
        <div class="pointer-events-none absolute -bottom-20 -right-20 h-64 w-64 rounded-full bg-forest-400/20 blur-3xl"></div>
        
        <div class="relative max-w-3xl mx-auto">
          <p class="inline-flex rounded-full border border-gold-300/30 bg-gold-300/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.16em] text-gold-200 mb-6">
            App Comparison 2026
          </p>
          <h1 class="font-display text-[clamp(2.1rem,4.5vw,4rem)] font-bold leading-[1.05] tracking-[-0.03em] mb-6">
            Dukaan AI vs Khatabook —<br /><span class="text-gold-200">Which is Better?</span>
          </h1>
          <p class="mx-auto max-w-2xl text-base leading-8 text-white/80 sm:text-lg mb-10">
            Khatabook tracks udhaar. Dukaan AI does that <em class="text-white">and</em> voice billing, GST invoices, AI bill scanning, inventory management — all <strong class="text-white">100% free</strong>.
          </p>
          <div class="flex flex-col gap-4 sm:flex-row sm:justify-center">
            <a
              href={site.playStoreUrl}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center justify-center gap-2 rounded-full bg-gold-300 px-8 py-4 text-sm font-bold text-forest-950 shadow-glow transition hover:-translate-y-0.5 hover:bg-gold-200"
            >
              ⬇ Switch to Dukaan AI
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Verdict Cards -->
    <section class="section-shell py-14 sm:py-20">
      <div class="mb-12 max-w-3xl mx-auto text-center">
        <h2 class="font-display text-3xl font-bold text-forest-950 sm:text-4xl">
          The Verdict at a Glance
        </h2>
      </div>

      <div class="grid gap-6 md:grid-cols-2 max-w-4xl mx-auto">
        <!-- Dukaan Card -->
        <div class="panel border-2 border-gold-300 bg-gradient-to-br from-forest-950 to-forest-900 px-8 py-10 rounded-[32px] text-white shadow-2xl shadow-forest-900/20 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-gold-400/10 rounded-full blur-2xl"></div>
          <span class="inline-block text-xs font-bold uppercase tracking-[0.18em] text-gold-300 mb-4">🏆 Dukaan AI</span>
          <h3 class="font-display text-2xl font-bold mb-6">Complete Shop Manager</h3>
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3"><Check class="text-gold-300 shrink-0" size={20}/><span class="text-white/90">Voice billing in 24 languages</span></li>
            <li class="flex items-start gap-3"><Check class="text-gold-300 shrink-0" size={20}/><span class="text-white/90">AI OCR bill scanner</span></li>
            <li class="flex items-start gap-3"><Check class="text-gold-300 shrink-0" size={20}/><span class="text-white/90">GST invoice generator</span></li>
            <li class="flex items-start gap-3"><Check class="text-gold-300 shrink-0" size={20}/><span class="text-white/90">Digital khata & udhaar tracking</span></li>
            <li class="flex items-start gap-3"><Check class="text-gold-300 shrink-0" size={20}/><span class="text-white/90">100% free with no paid tiers</span></li>
          </ul>
          <a href={site.playStoreUrl} target="_blank" rel="noreferrer" class="block w-full text-center rounded-full bg-gold-300 px-6 py-3.5 text-sm font-bold text-forest-950 transition hover:bg-gold-200 shadow-glow">
            ⬇ Download Free App
          </a>
        </div>

        <!-- Khatabook Card -->
        <div class="panel border border-forest-900/10 bg-white px-8 py-10 rounded-[32px]">
          <span class="inline-block text-xs font-bold uppercase tracking-[0.18em] text-forest-500 mb-4">Khatabook</span>
          <h3 class="font-display text-2xl font-bold text-forest-950 mb-6">Credit Ledger Only</h3>
          <ul class="space-y-4 text-forest-800">
            <li class="flex items-start gap-3"><Check class="text-forest-400 shrink-0" size={20}/><span>Udhaar / credit tracking</span></li>
            <li class="flex items-start gap-3"><Check class="text-forest-400 shrink-0" size={20}/><span>WhatsApp reminders</span></li>
            <li class="flex items-start gap-3 opacity-60"><X class="text-red-400 shrink-0" size={20}/><span>No voice billing</span></li>
            <li class="flex items-start gap-3 opacity-60"><X class="text-red-400 shrink-0" size={20}/><span>No AI bill scanning</span></li>
            <li class="flex items-start gap-3 opacity-60"><X class="text-red-400 shrink-0" size={20}/><span>Premium features require payment</span></li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Comparison Table -->
    <section class="section-shell py-14 sm:py-20 bg-forest-50/50">
      <div class="mb-12 max-w-3xl mx-auto text-center">
        <h2 class="font-display text-3xl font-bold text-forest-950 sm:text-4xl">
          Feature-by-Feature Comparison
        </h2>
      </div>

      <div class="max-w-4xl mx-auto overflow-hidden rounded-3xl border border-forest-900/10 bg-white shadow-lg">
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead class="bg-forest-900 text-white">
              <tr>
                <th class="p-5 font-semibold leading-none">Feature</th>
                <th class="p-5 text-center font-bold text-gold-300 leading-none">Dukaan AI 🏆</th>
                <th class="p-5 text-center font-semibold leading-none">Khatabook</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-forest-900/10">
              {rows.map((row, i) => (
                <tr class={i % 2 === 1 ? 'bg-forest-50/50' : 'bg-white'}>
                  <td class="p-5 font-medium text-forest-950">{row.feature}</td>
                  <td class={`p-5 text-center font-medium ${row.dukaanWin ? 'text-forest-600 bg-forest-50/30' : 'text-forest-900'}`}>
                    {row.dukaan}
                  </td>
                  <td class="p-5 text-center text-forest-700 opacity-80">
                    {row.other}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section-shell py-14 sm:py-20">
      <div class="mb-12 max-w-3xl mx-auto text-center">
        <h2 class="font-display text-3xl font-bold text-forest-950 sm:text-4xl">
          Dukaan AI vs Khatabook — FAQs
        </h2>
      </div>
      <div class="mx-auto max-w-3xl space-y-4">
        {faqs.map(faq => (
          <div class="panel rounded-2xl p-6">
            <h3 class="font-display text-lg font-bold text-forest-950">{faq.question}</h3>
            <p class="mt-3 text-sm leading-7 text-forest-800">{faq.answer}</p>
          </div>
        ))}
      </div>
    </section>

  </main>
  <SiteFooter />
</BaseLayout>
