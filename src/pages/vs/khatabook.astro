---
import { site } from "../../data/site";
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Dukaan AI vs Khatabook 2025 — Which is the Better Kirana App?";
const description = "Comparing Dukaan AI vs Khatabook for kirana stores. Dukaan AI offers voice billing in 24 languages, AI bill scanner, GST invoices, and 100% offline mode — all free. See the full comparison.";

const faqs = [
  {
    question: "Is Dukaan AI better than Khatabook for kirana stores?",
    answer: "Yes, Dukaan AI is better for kirana stores because it offers voice billing in 24 Indian languages, an AI bill scanner for supplier invoices, GST invoice generation, and a parchi scanner — features not available in Khatabook. Khatabook is primarily a credit ledger app. Dukaan AI is a complete free shop management solution for kirana retailers."
  },
  {
    question: "What can Dukaan AI do that Khatabook cannot?",
    answer: "Dukaan AI offers voice billing (speak to create bills), an AI-powered OCR bill scanner for supplier invoices, GST invoice generation, inventory tracking, wholesale order management, and a parchi scanner for handwritten customer lists. Khatabook focuses only on digital ledger management and does not offer voice billing or bill scanning."
  },
  {
    question: "Is Dukaan AI free like Khatabook?",
    answer: "Yes, Dukaan AI is completely free on Android with no subscription or trial limitations. All core features — voice billing, digital khata, udhaar tracking, GST invoices, and AI bill scanner — are available at zero cost. Unlike some Khatabook features that require a premium plan, Dukaan AI has no paid tiers."
  },
  {
    question: "Does Dukaan AI work offline like Khatabook?",
    answer: "Yes, Dukaan AI works 100% offline. All khata entries, billing records, and inventory data are stored on your phone. Dukaan AI also supports offline voice billing for 880+ kirana items — a feature Khatabook does not offer. Data syncs to the cloud automatically when internet is available."
  },
  {
    question: "Can I switch from Khatabook to Dukaan AI?",
    answer: "Yes, switching from Khatabook to Dukaan AI is simple. You can start by entering the opening balance for each customer directly in the Smart Khata section. Dukaan AI stores all your customer data securely, and you can export your records at any time. Most shopkeepers switch within 10 minutes."
  }
];

const rows = [
  { feature: "Voice Billing (Hindi & Regional)", dukaan: "✅ 24 languages", other: "❌ Not available" },
  { feature: "Digital Khata / Udhaar Tracking", dukaan: "✅ Included", other: "✅ Core feature" },
  { feature: "AI Bill Scanner (OCR)", dukaan: "✅ Scan supplier bills", other: "❌ Not available" },
  { feature: "GST Invoice Generation", dukaan: "✅ Auto GST slabs", other: "❌ Limited" },
  { feature: "Parchi / Handwritten List Scanner", dukaan: "✅ Included", other: "❌ Not available" },
  { feature: "Inventory Management", dukaan: "✅ Real-time tracking", other: "❌ Not available" },
  { feature: "WhatsApp Bill & Reminder Sharing", dukaan: "✅ One-tap share", other: "✅ Available" },
  { feature: "100% Offline Mode", dukaan: "✅ Full offline", other: "✅ Partial" },
  { feature: "Voice Billing Offline", dukaan: "✅ 880+ items offline", other: "❌ Not available" },
  { feature: "Completely Free Forever", dukaan: "✅ No paid tiers", other: "⚠️ Premium features paid" },
  { feature: "Android App", dukaan: "✅ Native Android", other: "✅ Available" },
  { feature: "24 Indian Languages", dukaan: "✅ 24 languages", other: "⚠️ Hindi only" }
];
---

<BaseLayout title={title} description={description} faqs={faqs}>
  <header style="background: linear-gradient(135deg, #0f3d23 0%, #195534 100%); padding: 0;">
    <div style="max-width: 900px; margin: 0 auto; padding: 24px 20px 16px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;">
      <a href="/" style="display: flex; align-items: center; gap: 10px; text-decoration: none;">
        <img src="/images/dukaan-logo.jpeg" alt="Dukaan AI logo" width="36" height="36" style="border-radius: 8px;" />
        <span style="color: #fff; font-size: 1.1rem; font-weight: 700;">Dukaan AI</span>
      </a>
      <a href={site.playStoreUrl} target="_blank" rel="noopener noreferrer"
        id="header-cta-vs-khatabook"
        style="background: #fbbf24; color: #0f3d23; padding: 10px 22px; border-radius: 50px; font-size: 0.9rem; font-weight: 700; text-decoration: none;">
        Try Dukaan AI Free
      </a>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section style="background: linear-gradient(135deg, #0f3d23 0%, #195534 100%); padding: 64px 20px 72px; text-align: center; color: #fff;">
      <div style="max-width: 740px; margin: 0 auto;">
        <p style="display: inline-block; background: rgba(251,191,36,0.18); color: #fbbf24; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; padding: 6px 16px; border-radius: 50px; margin-bottom: 24px;">
          App Comparison 2025
        </p>
        <h1 style="font-size: clamp(1.9rem, 5vw, 3rem); font-weight: 800; line-height: 1.15; margin-bottom: 20px; letter-spacing: -0.03em;">
          Dukaan AI vs Khatabook —<br />Which is Better for Your Kirana Store?
        </h1>
        <p style="font-size: 1.05rem; color: rgba(255,255,255,0.85); line-height: 1.7; max-width: 600px; margin: 0 auto 36px;">
          Khatabook tracks udhaar. Dukaan AI does that <em>and</em> voice billing, GST invoices, AI bill scanning, inventory management — all free. See why kirana owners are switching.
        </p>
        <a href={site.playStoreUrl} target="_blank" rel="noopener noreferrer"
          id="hero-cta-vs-khatabook"
          style="background: #fbbf24; color: #0f3d23; padding: 16px 32px; border-radius: 50px; font-size: 1rem; font-weight: 800; text-decoration: none;">
          Switch to Dukaan AI — Free
        </a>
      </div>
    </section>

    <!-- Verdict cards -->
    <section style="padding: 64px 20px; background: #f9fafb;">
      <div style="max-width: 820px; margin: 0 auto;">
        <h2 style="text-align: center; font-size: clamp(1.4rem, 3.5vw, 2rem); font-weight: 800; color: #0f3d23; margin-bottom: 40px;">
          The Verdict at a Glance
        </h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px;">
          <div style="background: linear-gradient(135deg, #0f3d23, #195534); border-radius: 20px; padding: 32px; color: #fff;">
            <p style="color: #fbbf24; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px;">🏆 Dukaan AI</p>
            <h3 style="font-size: 1.25rem; font-weight: 800; margin-bottom: 16px;">Complete Shop Manager</h3>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; font-size: 0.9rem;">
              <li>✅ Voice billing in 24 languages</li>
              <li>✅ AI bill scanner for suppliers</li>
              <li>✅ GST invoice generation</li>
              <li>✅ Digital khata & udhaar</li>
              <li>✅ Inventory tracking</li>
              <li>✅ 100% free — no paid tiers</li>
            </ul>
            <a href={site.playStoreUrl} target="_blank" rel="noopener noreferrer"
              style="display: block; margin-top: 24px; background: #fbbf24; color: #0f3d23; padding: 12px; border-radius: 50px; font-weight: 800; text-align: center; text-decoration: none; font-size: 0.9rem;">
              ⬇ Download Free
            </a>
          </div>
          <div style="background: #fff; border-radius: 20px; padding: 32px; border: 2px solid #e5e7eb;">
            <p style="color: #6b7280; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px;">Khatabook</p>
            <h3 style="font-size: 1.25rem; font-weight: 800; color: #0f3d23; margin-bottom: 16px;">Credit Ledger Only</h3>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; font-size: 0.9rem; color: #4b5563;">
              <li>✅ Udhaar / credit tracking</li>
              <li>✅ WhatsApp reminders</li>
              <li>❌ No voice billing</li>
              <li>❌ No AI bill scanner</li>
              <li>❌ No GST invoices</li>
              <li>⚠️ Premium features need paid plan</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Comparison Table -->
    <section style="padding: 0 20px 64px; background: #f9fafb;">
      <div style="max-width: 820px; margin: 0 auto;">
        <h2 style="text-align: center; font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 800; color: #0f3d23; margin-bottom: 32px;">
          Feature-by-Feature Comparison
        </h2>
        <div style="overflow-x: auto; border-radius: 16px; border: 1px solid #e5e7eb;">
          <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem;">
            <thead>
              <tr style="background: #0f3d23; color: #fff;">
                <th style="padding: 16px 20px; text-align: left; font-weight: 700;">Feature</th>
                <th style="padding: 16px 12px; text-align: center; color: #fbbf24; font-weight: 700;">Dukaan AI 🏆</th>
                <th style="padding: 16px 12px; text-align: center; font-weight: 600;">Khatabook</th>
              </tr>
            </thead>
            <tbody>
              {rows.map((row, i) => (
                <tr style={`background: ${i % 2 === 0 ? '#f9fafb' : '#fff'}`}>
                  <td style="padding: 14px 20px; color: #374151; font-weight: 500;">{row.feature}</td>
                  <td style="padding: 14px 12px; text-align: center; color: #374151;">{row.dukaan}</td>
                  <td style="padding: 14px 12px; text-align: center; color: #374151;">{row.other}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section style="padding: 64px 20px; background: #fff;">
      <div style="max-width: 720px; margin: 0 auto;">
        <h2 style="text-align: center; font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 800; color: #0f3d23; margin-bottom: 40px; letter-spacing: -0.02em;">
          Dukaan AI vs Khatabook — FAQ
        </h2>
        <div style="display: flex; flex-direction: column; gap: 16px;">
          {faqs.map(faq => (
            <div style="background: #f9fafb; border-radius: 14px; padding: 24px; border: 1px solid #e5e7eb;">
              <h3 style="font-size: 1rem; font-weight: 700; color: #0f3d23; margin-bottom: 10px;">{faq.question}</h3>
              <p style="font-size: 0.9rem; color: #4b5563; line-height: 1.7;">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section style="background: linear-gradient(135deg, #0f3d23 0%, #195534 100%); padding: 64px 20px; text-align: center;">
      <div style="max-width: 580px; margin: 0 auto; color: #fff;">
        <h2 style="font-size: clamp(1.6rem, 4vw, 2.3rem); font-weight: 800; margin-bottom: 16px; letter-spacing: -0.02em;">
          Switch from Khatabook to Dukaan AI — Free
        </h2>
        <p style="color: rgba(255,255,255,0.8); margin-bottom: 32px; line-height: 1.6;">
          Get voice billing, GST invoices, AI bill scanner, and digital khata — all in one free app. No paid plan needed.
        </p>
        <a href={site.playStoreUrl} target="_blank" rel="noopener noreferrer"
          id="cta-vs-khatabook-bottom"
          style="display: inline-block; background: #fbbf24; color: #0f3d23; padding: 18px 40px; border-radius: 50px; font-size: 1.05rem; font-weight: 800; text-decoration: none;">
          ⬇ Download Dukaan AI Free
        </a>
        <p style="margin-top: 14px; font-size: 0.8rem; color: rgba(255,255,255,0.4);">No registration required · No credit card · Switch in 10 minutes</p>
      </div>
    </section>

    <footer style="background: #0a2918; padding: 24px 20px; text-align: center;">
      <p style="color: rgba(255,255,255,0.4); font-size: 0.82rem;">
        © {new Date().getFullYear()} Dukaan AI · <a href="/vs/vyapar" style="color: rgba(255,255,255,0.5); text-decoration: none;">Dukaan AI vs Vyapar</a> · <a href="/kirana-billing-app" style="color: rgba(255,255,255,0.5); text-decoration: none;">Kirana Billing App</a> · <a href="/" style="color: rgba(255,255,255,0.5); text-decoration: none;">Home</a>
      </p>
    </footer>
  </main>
</BaseLayout>
