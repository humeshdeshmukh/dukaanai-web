---
import { site } from "../../data/site";
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Dukaan AI vs Vyapar 2025 — Which App is Better for Kirana Stores?";
const description = "Comparing Dukaan AI vs Vyapar for small kirana stores. Dukaan AI is free, works offline, has voice billing in 24 Indian languages, and needs zero accounting knowledge. See the full comparison.";

const faqs = [
  {
    question: "Is Dukaan AI better than Vyapar for kirana stores?",
    answer: "Yes. Dukaan AI is better for small kirana stores and chhoti dukaan owners. Vyapar is designed for larger, GST-registered businesses with complex accounting requirements. Dukaan AI is 100% free, works offline, supports voice billing in Hindi and 23 Indian languages, and requires no accounting knowledge — making it far more practical for everyday kirana shop management."
  },
  {
    question: "What is the main difference between Dukaan AI and Vyapar?",
    answer: "Vyapar is a full accounting and GST billing software designed for small and medium businesses with some accounting knowledge. Dukaan AI is a voice-first shop management app designed specifically for kirana retailers. Dukaan AI uniquely offers voice billing in 24 Indian languages, an AI bill scanner, digital khata, and offline voice recognition — none of which Vyapar provides."
  },
  {
    question: "Is Dukaan AI free while Vyapar is paid?",
    answer: "Yes. Dukaan AI is completely free on Android — all features including voice billing, digital khata, GST invoices, and AI bill scanner are available at no cost. Vyapar offers a free basic plan but charges for advanced features like auto-backup, multi-device access, and premium reports. Dukaan AI has no paid tiers."
  },
  {
    question: "Can Dukaan AI replace Vyapar for a small kirana shop?",
    answer: "Yes, for most kirana shop owners, Dukaan AI provides everything they need: voice billing, udhaar tracking, GST invoice generation, supplier bill scanning, inventory management, and WhatsApp sharing — all free. Vyapar may be more suitable if you manage multiple companies or need advanced accounting features like balance sheets and P&L statements."
  },
  {
    question: "Does Dukaan AI support GST billing like Vyapar?",
    answer: "Yes, Dukaan AI generates GST-compliant invoices with auto-calculation of 5%, 12%, and 18% GST slabs. You can share these professional invoices on WhatsApp instantly. While Vyapar offers more advanced GST reporting for larger businesses, Dukaan AI's GST features are fully sufficient for a typical kirana store's daily billing needs."
  }
];

const rows = [
  { feature: "Voice Billing in Hindi & Regional Languages", dukaan: "✅ 24 languages", other: "❌ Not available" },
  { feature: "Designed for Kirana / Small Shops", dukaan: "✅ Built for kirana", other: "⚠️ General SME focus" },
  { feature: "AI Bill Scanner (OCR)", dukaan: "✅ Scan supplier bills", other: "❌ Not available" },
  { feature: "100% Offline Mode", dukaan: "✅ Full offline", other: "✅ Available" },
  { feature: "Voice Billing Offline", dukaan: "✅ 880+ items", other: "❌ Not available" },
  { feature: "Digital Khata / Udhaar Tracking", dukaan: "✅ Included free", other: "⚠️ Basic in free plan" },
  { feature: "GST Invoice Generation", dukaan: "✅ Included free", other: "✅ Core feature" },
  { feature: "Advanced Accounting (P&L, Balance Sheet)", dukaan: "⚠️ Basic reports", other: "✅ Full accounting" },
  { feature: "Inventory Management", dukaan: "✅ Real-time", other: "✅ Available" },
  { feature: "WhatsApp Sharing", dukaan: "✅ One-tap", other: "✅ Available" },
  { feature: "Completely Free Forever", dukaan: "✅ No paid tiers", other: "⚠️ Free & paid plans" },
  { feature: "No Accounting Knowledge Required", dukaan: "✅ Zero training", other: "⚠️ Some learning curve" }
];
---

<BaseLayout title={title} description={description} faqs={faqs}>
  <header style="background: linear-gradient(135deg, #0f3d23 0%, #195534 100%); padding: 0;">
    <div style="max-width: 900px; margin: 0 auto; padding: 24px 20px 16px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;">
      <a href="/" style="display: flex; align-items: center; gap: 10px; text-decoration: none;">
        <img src="/images/dukaan-logo.jpeg" alt="Dukaan AI logo" width="36" height="36" style="border-radius: 8px;" />
        <span style="color: #fff; font-size: 1.1rem; font-weight: 700;">Dukaan AI</span>
      </a>
      <a href={site.playStoreUrl} target="_blank" rel="noopener noreferrer"
        id="header-cta-vs-vyapar"
        style="background: #fbbf24; color: #0f3d23; padding: 10px 22px; border-radius: 50px; font-size: 0.9rem; font-weight: 700; text-decoration: none;">
        Try Dukaan AI Free
      </a>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section style="background: linear-gradient(135deg, #0f3d23 0%, #195534 100%); padding: 64px 20px 72px; text-align: center; color: #fff;">
      <div style="max-width: 740px; margin: 0 auto;">
        <p style="display: inline-block; background: rgba(251,191,36,0.18); color: #fbbf24; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; padding: 6px 16px; border-radius: 50px; margin-bottom: 24px;">
          App Comparison 2025
        </p>
        <h1 style="font-size: clamp(1.9rem, 5vw, 3rem); font-weight: 800; line-height: 1.15; margin-bottom: 20px; letter-spacing: -0.03em;">
          Dukaan AI vs Vyapar —<br />Which is Better for Kirana Stores?
        </h1>
        <p style="font-size: 1.05rem; color: rgba(255,255,255,0.85); line-height: 1.7; max-width: 600px; margin: 0 auto 36px;">
          Vyapar is accounting software. Dukaan AI is a kirana shop assistant. Voice billing in 24 languages, AI bill scanner, offline mode — and completely free.
        </p>
        <a href={site.playStoreUrl} target="_blank" rel="noopener noreferrer"
          id="hero-cta-vs-vyapar"
          style="background: #fbbf24; color: #0f3d23; padding: 16px 32px; border-radius: 50px; font-size: 1rem; font-weight: 800; text-decoration: none;">
          Try Dukaan AI Free
        </a>
      </div>
    </section>

    <!-- Verdict Cards -->
    <section style="padding: 64px 20px; background: #f9fafb;">
      <div style="max-width: 820px; margin: 0 auto;">
        <h2 style="text-align: center; font-size: clamp(1.4rem, 3.5vw, 2rem); font-weight: 800; color: #0f3d23; margin-bottom: 40px;">
          Quick Verdict — Kirana Store Focus
        </h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px;">
          <div style="background: linear-gradient(135deg, #0f3d23, #195534); border-radius: 20px; padding: 32px; color: #fff;">
            <p style="color: #fbbf24; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px;">🏆 Dukaan AI — For Kirana Stores</p>
            <h3 style="font-size: 1.2rem; font-weight: 800; margin-bottom: 16px;">Voice-First Shop Management</h3>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; font-size: 0.88rem;">
              <li>✅ Voice billing in Hindi & 23 languages</li>
              <li>✅ AI OCR bill scanner</li>
              <li>✅ Digital khata & udhaar</li>
              <li>✅ GST invoice generation</li>
              <li>✅ Zero accounting knowledge needed</li>
              <li>✅ 100% free forever</li>
            </ul>
            <a href={site.playStoreUrl} target="_blank" rel="noopener noreferrer"
              style="display: block; margin-top: 24px; background: #fbbf24; color: #0f3d23; padding: 12px; border-radius: 50px; font-weight: 800; text-align: center; text-decoration: none; font-size: 0.9rem;">
              ⬇ Download Free
            </a>
          </div>
          <div style="background: #fff; border-radius: 20px; padding: 32px; border: 2px solid #e5e7eb;">
            <p style="color: #6b7280; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px;">Vyapar — For SMEs & Accountants</p>
            <h3 style="font-size: 1.2rem; font-weight: 800; color: #0f3d23; margin-bottom: 16px;">Full Accounting Software</h3>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; font-size: 0.88rem; color: #4b5563;">
              <li>✅ GST invoice generation</li>
              <li>✅ Inventory management</li>
              <li>✅ Balance sheet and P&L</li>
              <li>❌ No voice billing</li>
              <li>❌ No AI bill scanner</li>
              <li>⚠️ Advanced features need paid plan</li>
              <li>⚠️ Learning curve for non-accountants</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Comparison Table -->
    <section style="padding: 0 20px 64px; background: #f9fafb;">
      <div style="max-width: 820px; margin: 0 auto;">
        <h2 style="text-align: center; font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 800; color: #0f3d23; margin-bottom: 32px;">
          Feature Comparison: Dukaan AI vs Vyapar
        </h2>
        <div style="overflow-x: auto; border-radius: 16px; border: 1px solid #e5e7eb;">
          <table style="width: 100%; border-collapse: collapse; font-size: 0.9rem;">
            <thead>
              <tr style="background: #0f3d23; color: #fff;">
                <th style="padding: 16px 20px; text-align: left; font-weight: 700;">Feature</th>
                <th style="padding: 16px 12px; text-align: center; color: #fbbf24; font-weight: 700;">Dukaan AI 🏆</th>
                <th style="padding: 16px 12px; text-align: center; font-weight: 600;">Vyapar</th>
              </tr>
            </thead>
            <tbody>
              {rows.map((row, i) => (
                <tr style={`background: ${i % 2 === 0 ? '#f9fafb' : '#fff'}`}>
                  <td style="padding: 14px 20px; color: #374151; font-weight: 500;">{row.feature}</td>
                  <td style="padding: 14px 12px; text-align: center; color: #374151;">{row.dukaan}</td>
                  <td style="padding: 14px 12px; text-align: center; color: #374151;">{row.other}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section style="padding: 64px 20px; background: #fff;">
      <div style="max-width: 720px; margin: 0 auto;">
        <h2 style="text-align: center; font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 800; color: #0f3d23; margin-bottom: 40px;">
          Dukaan AI vs Vyapar — FAQ
        </h2>
        <div style="display: flex; flex-direction: column; gap: 16px;">
          {faqs.map(faq => (
            <div style="background: #f9fafb; border-radius: 14px; padding: 24px; border: 1px solid #e5e7eb;">
              <h3 style="font-size: 1rem; font-weight: 700; color: #0f3d23; margin-bottom: 10px;">{faq.question}</h3>
              <p style="font-size: 0.9rem; color: #4b5563; line-height: 1.7;">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section style="background: linear-gradient(135deg, #0f3d23 0%, #195534 100%); padding: 64px 20px; text-align: center;">
      <div style="max-width: 580px; margin: 0 auto; color: #fff;">
        <h2 style="font-size: clamp(1.6rem, 4vw, 2.3rem); font-weight: 800; margin-bottom: 16px;">
          Free Vyapar Alternative for Kirana Stores
        </h2>
        <p style="color: rgba(255,255,255,0.8); margin-bottom: 32px; line-height: 1.6;">
          Dukaan AI gives kirana shop owners voice billing, digital khata, GST invoices & AI bill scanning — all free. No accounting knowledge needed.
        </p>
        <a href={site.playStoreUrl} target="_blank" rel="noopener noreferrer"
          id="cta-vs-vyapar-bottom"
          style="display: inline-block; background: #fbbf24; color: #0f3d23; padding: 18px 40px; border-radius: 50px; font-size: 1.05rem; font-weight: 800; text-decoration: none;">
          ⬇ Download Dukaan AI Free
        </a>
        <p style="margin-top: 14px; font-size: 0.8rem; color: rgba(255,255,255,0.4);">No registration required · No credit card · Android only</p>
      </div>
    </section>

    <footer style="background: #0a2918; padding: 24px 20px; text-align: center;">
      <p style="color: rgba(255,255,255,0.4); font-size: 0.82rem;">
        © {new Date().getFullYear()} Dukaan AI · <a href="/vs/khatabook" style="color: rgba(255,255,255,0.5); text-decoration: none;">Dukaan AI vs Khatabook</a> · <a href="/kirana-billing-app" style="color: rgba(255,255,255,0.5); text-decoration: none;">Kirana Billing App</a> · <a href="/" style="color: rgba(255,255,255,0.5); text-decoration: none;">Home</a>
      </p>
    </footer>
  </main>
</BaseLayout>
