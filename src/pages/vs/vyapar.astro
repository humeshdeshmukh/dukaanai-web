---
import { site } from "../../data/site";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { Check, X } from "@lucide/astro";

const title = "Dukaan AI vs Vyapar 2025 — Which App is Better for Kirana Stores?";
const description = "Comparing Dukaan AI vs Vyapar for small kirana stores. Dukaan AI is free, works offline, has voice billing in 24 Indian languages, and needs zero accounting knowledge. See the full comparison.";

const faqs = [
  {
    question: "Is Dukaan AI better than Vyapar for kirana stores?",
    answer: "Yes. Dukaan AI is better for small kirana stores and chhoti dukaan owners. Vyapar is designed for larger, GST-registered businesses with complex accounting requirements. Dukaan AI is 100% free, works offline, supports voice billing in Hindi and 23 Indian languages, and requires no accounting knowledge — making it far more practical for everyday kirana shop management."
  },
  {
    question: "What is the main difference between Dukaan AI and Vyapar?",
    answer: "Vyapar is a full accounting and GST billing software designed for small and medium businesses with some accounting knowledge. Dukaan AI is a voice-first shop management app designed specifically for kirana retailers. Dukaan AI uniquely offers voice billing in 24 Indian languages, an AI bill scanner, digital khata, and offline voice recognition — none of which Vyapar provides."
  },
  {
    question: "Is Dukaan AI free while Vyapar is paid?",
    answer: "Yes. Dukaan AI is completely free on Android — all features including voice billing, digital khata, GST invoices, and AI bill scanner are available at no cost. Vyapar offers a free basic plan but charges for advanced features like auto-backup, multi-device access, and premium reports. Dukaan AI has no paid tiers."
  },
  {
    question: "Can Dukaan AI replace Vyapar for a small kirana shop?",
    answer: "Yes, for most kirana shop owners, Dukaan AI provides everything they need: voice billing, udhaar tracking, GST invoice generation, supplier bill scanning, inventory management, and WhatsApp sharing — all free. Vyapar may be more suitable if you manage multiple companies or need advanced accounting features like balance sheets and P&L statements."
  },
  {
    question: "Does Dukaan AI support GST billing like Vyapar?",
    answer: "Yes, Dukaan AI generates GST-compliant invoices with auto-calculation of 5%, 12%, and 18% GST slabs. You can share these professional invoices on WhatsApp instantly. While Vyapar offers more advanced GST reporting for larger businesses, Dukaan AI's GST features are fully sufficient for a typical kirana store's daily billing needs."
  }
];

const rows = [
  { feature: "Voice Billing in Hindi & Regional Languages", dukaan: "✅ 24 languages", other: "❌ Not available", dukaanWin: true },
  { feature: "Designed for Kirana / Small Shops", dukaan: "✅ Built for kirana", other: "⚠️ General SME focus", dukaanWin: true },
  { feature: "AI Bill Scanner (OCR)", dukaan: "✅ Scan supplier bills", other: "❌ Not available", dukaanWin: true },
  { feature: "100% Offline Mode", dukaan: "✅ Full offline", other: "✅ Available", dukaanWin: null },
  { feature: "Voice Billing Offline", dukaan: "✅ 880+ items", other: "❌ Not available", dukaanWin: true },
  { feature: "Digital Khata / Udhaar Tracking", dukaan: "✅ Included free", other: "⚠️ Basic in free plan", dukaanWin: true },
  { feature: "GST Invoice Generation", dukaan: "✅ Included free", other: "✅ Core feature", dukaanWin: null },
  { feature: "Advanced Accounting (P&L, Balance Sheet)", dukaan: "⚠️ Basic reports", other: "✅ Full accounting", dukaanWin: false },
  { feature: "Inventory Management", dukaan: "✅ Real-time", other: "✅ Available", dukaanWin: null },
  { feature: "WhatsApp Sharing", dukaan: "✅ One-tap", other: "✅ Available", dukaanWin: null },
  { feature: "Completely Free Forever", dukaan: "✅ No paid tiers", other: "⚠️ Free & paid plans", dukaanWin: true },
  { feature: "No Accounting Knowledge Required", dukaan: "✅ Zero training", other: "⚠️ Some learning curve", dukaanWin: true }
];
---

<BaseLayout title={title} description={description} faqs={faqs}>
  <SiteHeader />

  <main>
    <!-- Hero -->
    <section class="section-shell pb-16 pt-8 sm:pb-24 sm:pt-14">
      <div class="relative overflow-hidden rounded-[42px] border border-white/55 bg-gradient-to-br from-forest-950 via-forest-900 to-forest-800 px-5 py-12 text-center text-white shadow-2xl sm:px-7 lg:px-10">
        <div class="pointer-events-none absolute -left-20 -top-20 h-64 w-64 rounded-full bg-gold-400/20 blur-3xl"></div>
        <div class="pointer-events-none absolute -bottom-20 -right-20 h-64 w-64 rounded-full bg-forest-400/20 blur-3xl"></div>
        
        <div class="relative max-w-3xl mx-auto">
          <p class="inline-flex rounded-full border border-gold-300/30 bg-gold-300/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.16em] text-gold-200 mb-6">
            App Comparison 2025
          </p>
          <h1 class="font-display text-[clamp(2.1rem,4vw,4rem)] font-bold leading-[1.05] tracking-[-0.03em] mb-6">
            Dukaan AI vs Vyapar —<br /><span class="text-gold-200">Which is Better?</span>
          </h1>
          <p class="mx-auto max-w-2xl text-base leading-8 text-white/80 sm:text-lg mb-10">
            Vyapar is accounting software. Dukaan AI is a kirana shop assistant. Voice billing in 24 languages, AI bill scanner, offline mode — and <strong class="text-white">completely free</strong>.
          </p>
          <div class="flex flex-col gap-4 sm:flex-row sm:justify-center">
            <a
              href={site.playStoreUrl}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center justify-center gap-2 rounded-full bg-gold-300 px-8 py-4 text-sm font-bold text-forest-950 shadow-glow transition hover:-translate-y-0.5 hover:bg-gold-200"
            >
              ⬇ Try Dukaan AI Free
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Verdict Cards -->
    <section class="section-shell py-14 sm:py-20">
      <div class="mb-12 max-w-3xl mx-auto text-center">
        <h2 class="font-display text-3xl font-bold text-forest-950 sm:text-4xl">
          Quick Verdict — Kirana Store Focus
        </h2>
      </div>

      <div class="grid gap-6 md:grid-cols-2 max-w-4xl mx-auto">
        <!-- Dukaan Card -->
        <div class="panel border-2 border-gold-300 bg-gradient-to-br from-forest-950 to-forest-900 px-8 py-10 rounded-[32px] text-white shadow-2xl shadow-forest-900/20 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-32 h-32 bg-gold-400/10 rounded-full blur-2xl"></div>
          <span class="inline-block text-xs font-bold uppercase tracking-[0.18em] text-gold-300 mb-4">🏆 Dukaan AI — For Kirana Stores</span>
          <h3 class="font-display text-2xl font-bold mb-6">Voice-First Shop Management</h3>
          <ul class="space-y-4 mb-8">
            <li class="flex items-start gap-3"><Check class="text-gold-300 shrink-0" size={20}/><span class="text-white/90">Voice billing in Hindi & 23 languages</span></li>
            <li class="flex items-start gap-3"><Check class="text-gold-300 shrink-0" size={20}/><span class="text-white/90">AI OCR bill scanner</span></li>
            <li class="flex items-start gap-3"><Check class="text-gold-300 shrink-0" size={20}/><span class="text-white/90">Digital khata & udhaar</span></li>
            <li class="flex items-start gap-3"><Check class="text-gold-300 shrink-0" size={20}/><span class="text-white/90">Zero accounting knowledge needed</span></li>
            <li class="flex items-start gap-3"><Check class="text-gold-300 shrink-0" size={20}/><span class="text-white/90">100% free forever</span></li>
          </ul>
          <a href={site.playStoreUrl} target="_blank" rel="noreferrer" class="block w-full text-center rounded-full bg-gold-300 px-6 py-3.5 text-sm font-bold text-forest-950 transition hover:bg-gold-200 shadow-glow">
            ⬇ Download Free App
          </a>
        </div>

        <!-- Vyapar Card -->
        <div class="panel border border-forest-900/10 bg-white px-8 py-10 rounded-[32px]">
          <span class="inline-block text-xs font-bold uppercase tracking-[0.18em] text-forest-500 mb-4">Vyapar — For SMEs & Accountants</span>
          <h3 class="font-display text-2xl font-bold text-forest-950 mb-6">Full Accounting Software</h3>
          <ul class="space-y-4 text-forest-800">
            <li class="flex items-start gap-3"><Check class="text-forest-400 shrink-0" size={20}/><span>GST invoice generation</span></li>
            <li class="flex items-start gap-3"><Check class="text-forest-400 shrink-0" size={20}/><span>Balance sheet and P&L</span></li>
            <li class="flex items-start gap-3 opacity-60"><X class="text-red-400 shrink-0" size={20}/><span>No voice billing or AI scanner</span></li>
            <li class="flex items-start gap-3 opacity-60"><X class="text-red-400 shrink-0" size={20}/><span>Advanced features need paid plan</span></li>
            <li class="flex items-start gap-3 opacity-60"><X class="text-red-400 shrink-0" size={20}/><span>Learning curve for non-accountants</span></li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Comparison Table -->
    <section class="section-shell py-14 sm:py-20 bg-forest-50/50">
      <div class="mb-12 max-w-3xl mx-auto text-center">
        <h2 class="font-display text-3xl font-bold text-forest-950 sm:text-4xl">
          Feature Comparison: Dukaan AI vs Vyapar
        </h2>
      </div>

      <div class="max-w-4xl mx-auto overflow-hidden rounded-3xl border border-forest-900/10 bg-white shadow-lg">
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead class="bg-forest-900 text-white">
              <tr>
                <th class="p-5 font-semibold leading-none">Feature</th>
                <th class="p-5 text-center font-bold text-gold-300 leading-none">Dukaan AI 🏆</th>
                <th class="p-5 text-center font-semibold leading-none">Vyapar</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-forest-900/10">
              {rows.map((row, i) => (
                <tr class={i % 2 === 1 ? 'bg-forest-50/50' : 'bg-white'}>
                  <td class="p-5 font-medium text-forest-950">{row.feature}</td>
                  <td class={`p-5 text-center font-medium ${row.dukaanWin === true ? 'text-forest-600 bg-forest-50/30' : 'text-forest-900'}`}>
                    {row.dukaan}
                  </td>
                  <td class={`p-5 text-center opacity-80 ${row.dukaanWin === false ? 'text-forest-600 font-medium' : 'text-forest-700'}`}>
                    {row.other}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section-shell py-14 sm:py-20">
      <div class="mb-12 max-w-3xl mx-auto text-center">
        <h2 class="font-display text-3xl font-bold text-forest-950 sm:text-4xl">
          Dukaan AI vs Vyapar — FAQs
        </h2>
      </div>
      <div class="mx-auto max-w-3xl space-y-4">
        {faqs.map(faq => (
          <div class="panel rounded-2xl p-6">
            <h3 class="font-display text-lg font-bold text-forest-950">{faq.question}</h3>
            <p class="mt-3 text-sm leading-7 text-forest-800">{faq.answer}</p>
          </div>
        ))}
      </div>
    </section>

  </main>
  <SiteFooter />
</BaseLayout>
