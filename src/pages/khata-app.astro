---
import { site } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Free Digital Khata App for Kirana Store | Udhaar & Payment Tracker | Dukaan AI";
const description = "Dukaan AI is India's best free khata app for kirana stores. Manage udhaar, track payments, send WhatsApp reminders & replace your paper bahi khata — 100% offline & free on Android.";

const faqs = [
  {
    question: "What is the best free khata app for kirana stores in India?",
    answer: "Dukaan AI is the best free digital khata app for kirana stores in India. It lets you record udhaar (credit given) and jama (payment received), send WhatsApp reminders, generate customer statements, and manage all your bahi khata digitally — completely free on Android with full offline support."
  },
  {
    question: "How is Dukaan AI khata app different from Khatabook?",
    answer: "Dukaan AI is a complete shop management app while Khatabook focuses mainly on credit tracking. Dukaan AI includes voice billing in 24 Indian languages, an AI bill scanner, GST invoice generation, and a parchi scanner — features not available in Khatabook. It is also 100% offline and completely free, with no premium upsells."
  },
  {
    question: "Can I use khata app without internet?",
    answer: "Yes, Dukaan AI works fully offline. All udhaar entries, payments, and customer records are stored on your phone. When internet is available, everything syncs to the cloud automatically. This makes it ideal for kirana stores in areas with poor network connectivity."
  },
  {
    question: "How do I send WhatsApp payment reminders using khata app?",
    answer: "In Dukaan AI, open any customer profile in your digital khata, tap 'Send Reminder', and a professional WhatsApp message with the balance amount is sent automatically. You can also share a detailed PDF statement with full transaction history to help customers verify their balance."
  },
  {
    question: "Is there a free udhaar khata app for Android?",
    answer: "Yes, Dukaan AI is a completely free udhaar khata app for Android. There is no subscription, no trial period, and no hidden fee. You can manage unlimited customers, record unlimited transactions, and send unlimited WhatsApp reminders — all for free."
  },
  {
    question: "Can I manage multiple shops with a khata app?",
    answer: "Yes, Dukaan AI lets you manage multiple shop profiles from a single Android device. Each business has its own separate khata, billing records, inventory, and customer list. This is useful for shop owners running more than one store or selling in different locations."
  }
];

const steps = [
  { num: "1", title: "Add Customer", desc: "Search by name or phone number. Add new customers with one tap — no form to fill." },
  { num: "2", title: "Record Baki or Jama", desc: "Enter udhaar given (baki) or payment received (jama). Add a note or photo of the slip." },
  { num: "3", title: "Send WhatsApp Reminder", desc: "Tap the WhatsApp icon to instantly send a professional balance reminder to your customer." }
];

const benefits = [
  { title: "Replace Paper Bahi Khata", desc: "Go paperless. Stop losing records. All your khata entries are safe, searchable, and backed up in the cloud." },
  { title: "Auto WhatsApp Reminders", desc: "Send payment reminders to customers with one tap — no typing the message yourself." },
  { title: "Customer Payment Portal", desc: "Each customer gets a unique link to see their balance and pay you via UPI directly." },
  { title: "Photo Proof Attachments", desc: "Attach a photo of the signed slip to every khata entry to prevent disputes." },
  { title: "Credit Limit Alerts", desc: "Set a credit limit per customer and get alerted when they cross their safe borrow level." },
  { title: "Detailed PDF Statements", desc: "Share a professional month-wise statement with full transaction history on WhatsApp." }
];
---

<BaseLayout title={title} description={description} faqs={faqs}>
  <header style="background: linear-gradient(135deg, #0f3d23 0%, #195534 100%); padding: 0;">
    <div style="max-width: 900px; margin: 0 auto; padding: 24px 20px 16px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px;">
      <a href="/" style="display: flex; align-items: center; gap: 10px; text-decoration: none;">
        <img src="/images/dukaan-logo.jpeg" alt="Dukaan AI logo" width="36" height="36" style="border-radius: 8px;" />
        <span style="color: #fff; font-size: 1.1rem; font-weight: 700; letter-spacing: -0.3px;">Dukaan AI</span>
      </a>
      <a href={site.playStoreUrl} target="_blank" rel="noopener noreferrer"
        id="header-cta-khata"
        style="background: #fbbf24; color: #0f3d23; padding: 10px 22px; border-radius: 50px; font-size: 0.9rem; font-weight: 700; text-decoration: none;">
        ⬇ Free Khata App
      </a>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section style="background: linear-gradient(135deg, #0f3d23 0%, #195534 100%); padding: 64px 20px 72px; text-align: center; color: #fff;">
      <div style="max-width: 760px; margin: 0 auto;">
        <p style="display: inline-block; background: rgba(251,191,36,0.18); color: #fbbf24; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; padding: 6px 16px; border-radius: 50px; margin-bottom: 24px;">
          Free Digital Bahi Khata App for India
        </p>
        <h1 style="font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 800; line-height: 1.15; margin-bottom: 20px; letter-spacing: -0.03em;">
          Free Digital Khata App —<br />Udhaar & Payment Tracker for Kirana Store
        </h1>
        <p style="font-size: 1.1rem; color: rgba(255,255,255,0.85); line-height: 1.7; max-width: 620px; margin: 0 auto 36px;">
          Replace your paper bahi khata. Track customer credit (udhaar), record payments (jama), send WhatsApp reminders — all <strong>free and offline</strong> on Android.
        </p>
        <div style="display: flex; gap: 14px; flex-wrap: wrap; justify-content: center;">
          <a href={site.playStoreUrl} target="_blank" rel="noopener noreferrer"
            id="hero-cta-khata-playstore"
            style="background: #fbbf24; color: #0f3d23; padding: 16px 32px; border-radius: 50px; font-size: 1rem; font-weight: 800; text-decoration: none;">
            ⬇ Download Free Khata App
          </a>
          <a href={`mailto:${site.businessEmail}`}
            style="background: rgba(255,255,255,0.12); color: #fff; padding: 16px 32px; border-radius: 50px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 1px solid rgba(255,255,255,0.25);">
            Contact Us
          </a>
        </div>
        <p style="margin-top: 20px; font-size: 0.82rem; color: rgba(255,255,255,0.55);">
          4.5★ · Free forever · 24 Indian languages · 100% offline
        </p>
      </div>
    </section>

    <!-- How it works -->
    <section style="padding: 64px 20px; background: #fff;">
      <div style="max-width: 820px; margin: 0 auto;">
        <p style="text-align:center; font-size: 0.8rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #195534; margin-bottom: 10px;">Simple 3-Step Process</p>
        <h2 style="text-align: center; font-size: clamp(1.5rem, 3.5vw, 2.2rem); font-weight: 800; color: #0f3d23; margin-bottom: 48px; letter-spacing: -0.02em;">
          How to Use Digital Khata in Dukaan AI
        </h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 24px;">
          {steps.map(s => (
            <div style="text-align: center; background: #f9fafb; border-radius: 16px; padding: 32px 20px;">
              <div style="width: 52px; height: 52px; background: #0f3d23; color: #fbbf24; border-radius: 50%; font-size: 1.4rem; font-weight: 800; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;">{s.num}</div>
              <h3 style="font-size: 1rem; font-weight: 700; color: #0f3d23; margin-bottom: 8px;">{s.title}</h3>
              <p style="font-size: 0.88rem; color: #4b5563; line-height: 1.6;">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Benefits -->
    <section style="padding: 64px 20px; background: #f9fafb;">
      <div style="max-width: 880px; margin: 0 auto;">
        <h2 style="text-align: center; font-size: clamp(1.5rem, 3.5vw, 2.2rem); font-weight: 800; color: #0f3d23; margin-bottom: 48px; letter-spacing: -0.02em;">
          Why Kirana Owners Love Dukaan AI Khata App
        </h2>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px;">
          {benefits.map(b => (
            <div style="background: #fff; border-radius: 14px; padding: 24px; border: 1px solid #e5e7eb;">
              <h3 style="font-size: 0.95rem; font-weight: 700; color: #0f3d23; margin-bottom: 8px;">✅ {b.title}</h3>
              <p style="font-size: 0.88rem; color: #4b5563; line-height: 1.6;">{b.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section style="padding: 64px 20px; background: #fff;">
      <div style="max-width: 720px; margin: 0 auto;">
        <h2 style="text-align: center; font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 800; color: #0f3d23; margin-bottom: 40px; letter-spacing: -0.02em;">
          Frequently Asked Questions — Khata App
        </h2>
        <div style="display: flex; flex-direction: column; gap: 16px;">
          {faqs.map(faq => (
            <div style="background: #f9fafb; border-radius: 14px; padding: 24px; border: 1px solid #e5e7eb;">
              <h3 style="font-size: 1rem; font-weight: 700; color: #0f3d23; margin-bottom: 10px;">{faq.question}</h3>
              <p style="font-size: 0.9rem; color: #4b5563; line-height: 1.7;">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section style="background: linear-gradient(135deg, #0f3d23 0%, #195534 100%); padding: 64px 20px; text-align: center;">
      <div style="max-width: 600px; margin: 0 auto; color: #fff;">
        <h2 style="font-size: clamp(1.6rem, 4vw, 2.4rem); font-weight: 800; margin-bottom: 16px; letter-spacing: -0.02em;">
          Switch to Digital Khata — Free Forever
        </h2>
        <p style="color: rgba(255,255,255,0.8); font-size: 1rem; margin-bottom: 32px; line-height: 1.6;">
          Join lakhs of kirana shop owners who replaced their paper bahi khata with Dukaan AI — free, offline, and trusted.
        </p>
        <a href={site.playStoreUrl} target="_blank" rel="noopener noreferrer"
          id="footer-cta-khata"
          style="display: inline-block; background: #fbbf24; color: #0f3d23; padding: 18px 40px; border-radius: 50px; font-size: 1.05rem; font-weight: 800; text-decoration: none;">
          ⬇ Download Free Khata App
        </a>
        <p style="margin-top: 16px; font-size: 0.8rem; color: rgba(255,255,255,0.45);">No registration · No credit card · Completely free</p>
      </div>
    </section>

    <!-- Footer -->
    <footer style="background: #0a2918; padding: 24px 20px; text-align: center;">
      <p style="color: rgba(255,255,255,0.4); font-size: 0.82rem;">
        © {new Date().getFullYear()} Dukaan AI · <a href="/legal/privacy-policy" style="color: rgba(255,255,255,0.5); text-decoration: none;">Privacy Policy</a> · <a href="/legal/terms-of-service" style="color: rgba(255,255,255,0.5); text-decoration: none;">Terms</a> · <a href="/kirana-billing-app" style="color: rgba(255,255,255,0.5); text-decoration: none;">Kirana Billing App</a> · <a href="/" style="color: rgba(255,255,255,0.5); text-decoration: none;">Home</a>
      </p>
    </footer>
  </main>
</BaseLayout>
