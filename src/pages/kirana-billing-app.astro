---
import { site } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { ArrowUpRight, Check, X } from "@lucide/astro";

const title = "Free Kirana Billing App Download | Voice Billing & GST Invoice | Dukaan AI";
const description = "Download India's best free kirana billing app. Dukaan AI lets you create GST bills by speaking in Hindi, manage inventory, track udhaar & print invoices — 100% offline. No subscription.";

const faqs = [
  {
    question: "Which is the best free kirana billing app in India?",
    answer: "Dukaan AI is the best free kirana billing app in India. It offers voice billing in 24 Indian languages, GST invoice generation, digital khata for udhaar tracking, AI bill scanner for supplier invoices, and full offline capability — all in one free Android app with no subscription fee."
  },
  {
    question: "Is there a kirana billing app that works without internet?",
    answer: "Yes, Dukaan AI works 100% offline. You can create bills, record udhaar, manage inventory, and even use voice billing for 880+ common kirana items without any internet connection. Data syncs automatically when connectivity returns."
  },
  {
    question: "Can I create GST invoices with a kirana billing app?",
    answer: "Yes, Dukaan AI auto-calculates GST at 5%, 12%, and 18% slabs on every item. You can generate professional GST invoices by voice or tap, and share them directly on WhatsApp with your customer in seconds."
  },
  {
    question: "Is kirana billing app available in Hindi?",
    answer: "Yes, Dukaan AI supports voice billing in Hindi, Hinglish, and 22 more Indian regional languages. You can speak common kirana items like 'Chini 2 kilo' or 'Sabun 1 piece' and the app builds the bill automatically."
  },
  {
    question: "How do I download Dukaan AI kirana billing app?",
    answer: "Dukaan AI is free on Google Play Store. Search 'Dukaan AI' on your Android phone, tap Install, and start managing your kirana store with voice billing, digital khata, and AI bill scanning — completely free."
  },
  {
    question: "Does kirana billing app support inventory management?",
    answer: "Yes, Dukaan AI tracks your stock in real time. When you scan a supplier bill, items are automatically added to inventory. You receive low-stock alerts for essentials like Sugar, Tea, and Soap so you never run out."
  }
];

const features = [
  {
    icon: "🎤",
    title: "Voice Billing in Hindi & 23 Languages",
    desc: "Speak items like 'Chini 2 kilo' and the bill is built automatically. No typing, no slow barcode scanning."
  },
  {
    icon: "📒",
    title: "Digital Khata — Udhaar & Payments",
    desc: "Record customer credit (baki) and payments (jama) digitally. Send WhatsApp reminders with one tap."
  },
  {
    icon: "🧾",
    title: "GST Invoice Generator",
    desc: "Auto-calculate GST and generate professional invoices. Share via WhatsApp instantly — no printer needed."
  },
  {
    icon: "📷",
    title: "AI Bill Scanner",
    desc: "Scan supplier purchase bills with your camera. AI extracts items, qty, and price — updates stock automatically."
  },
  {
    icon: "📦",
    title: "Inventory Tracking",
    desc: "Real-time stock levels with auto low-stock alerts for every kirana item. Never over-order or stock-out again."
  },
  {
    icon: "📶",
    title: "100% Offline Mode",
    desc: "Works fully without internet. Perfect for kirana shops in areas with poor network. All data is safe on your phone."
  }
];

const comparison = [
  { feature: "Voice Billing in Hindi", dukaan: true, khatabook: false, vyapar: false },
  { feature: "24 Indian Languages", dukaan: true, khatabook: false, vyapar: false },
  { feature: "100% Offline Mode", dukaan: true, khatabook: true, vyapar: true },
  { feature: "AI Bill Scanner (OCR)", dukaan: true, khatabook: false, vyapar: false },
  { feature: "Parchi / List Scanner", dukaan: true, khatabook: false, vyapar: false },
  { feature: "GST Invoice Generation", dukaan: true, khatabook: false, vyapar: true },
  { feature: "Udhaar / Khata Tracking", dukaan: true, khatabook: true, vyapar: true },
  { feature: "WhatsApp Bill Sharing", dukaan: true, khatabook: true, vyapar: true },
  { feature: "Completely Free Forever", dukaan: true, khatabook: false, vyapar: false },
  { feature: "No Accounting Knowledge Needed", dukaan: true, khatabook: true, vyapar: false }
];
---

<BaseLayout title={title} description={description} faqs={faqs}>
  <SiteHeader />
  
  <main>
    <!-- Hero -->
    <section class="section-shell pb-16 pt-8 sm:pb-24 sm:pt-14">
      <div class="relative overflow-hidden rounded-[42px] border border-white/55 bg-gradient-to-br from-forest-950 via-forest-900 to-forest-800 px-5 py-12 text-center text-white shadow-2xl sm:px-7 lg:px-10">
        <div class="pointer-events-none absolute -left-20 -top-20 h-64 w-64 rounded-full bg-gold-400/20 blur-3xl"></div>
        <div class="pointer-events-none absolute -bottom-20 -right-20 h-64 w-64 rounded-full bg-forest-400/20 blur-3xl"></div>
        
        <div class="relative max-w-3xl mx-auto">
          <p class="inline-flex rounded-full border border-gold-300/30 bg-gold-300/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.16em] text-gold-200 mb-6">
            India's #1 Free Kirana Billing App
          </p>
          <h1 class="font-display text-[clamp(2.4rem,5vw,4.5rem)] font-bold leading-[1.05] tracking-[-0.03em] mb-6">
            Free Kirana Billing App —<br /><span class="text-gold-200">Voice Billing, Khata & GST Invoice</span>
          </h1>
          <p class="mx-auto max-w-2xl text-base leading-8 text-white/80 sm:text-lg mb-10">
            Manage your kirana store without typing. Speak items in Hindi to create bills, track udhaar digitally, scan supplier bills with AI, and generate GST invoices — all <strong class="text-white">100% free & offline</strong>.
          </p>
          <div class="flex flex-col gap-4 sm:flex-row sm:justify-center">
            <a
              href={site.playStoreUrl}
              target="_blank"
              rel="noreferrer"
              class="inline-flex items-center justify-center gap-2 rounded-full bg-gold-300 px-8 py-4 text-sm font-bold text-forest-950 shadow-glow transition hover:-translate-y-0.5 hover:bg-gold-200"
            >
              ⬇ Download Free on Android
            </a>
            <a
              href="#features"
              class="inline-flex items-center justify-center rounded-full border border-white/20 bg-white/10 px-8 py-4 text-sm font-bold text-white transition hover:bg-white/20"
            >
              See All Features
            </a>
          </div>
          <p class="mt-6 text-sm text-white/50">
            4.5★ rated · 24 Indian languages · Works offline · No subscription
          </p>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="section-shell py-14 sm:py-20">
      <div class="mb-12 max-w-3xl mx-auto text-center">
        <span class="text-xs font-bold uppercase tracking-[0.18em] text-forest-700">Everything You Need</span>
        <h2 class="mt-4 font-display text-3xl font-bold text-forest-950 sm:text-4xl">
          Complete Kirana Store Billing Software
        </h2>
        <p class="mt-4 text-base leading-8 text-forest-800">
          From voice billing to AI scanner, Dukaan AI replaces your paper register, Khatabook, and separate billing app — in one free app.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
        {features.map(f => (
          <div class="panel border border-forest-900/10 bg-white px-6 py-8 transition hover:border-gold-300 hover:shadow-xl rounded-3xl">
            <div class="text-3xl mb-4">{f.icon}</div>
            <h3 class="font-display text-xl font-bold text-forest-950 mb-2">{f.title}</h3>
            <p class="text-sm leading-7 text-forest-800">{f.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Comparison Table -->
    <section class="section-shell py-14 sm:py-20 bg-forest-50/50">
      <div class="mb-12 max-w-3xl mx-auto text-center">
        <h2 class="font-display text-3xl font-bold text-forest-950 sm:text-4xl">
          Dukaan AI vs Khatabook vs Vyapar
        </h2>
        <p class="mt-4 text-base leading-8 text-forest-800">
          See why thousands of kirana store owners switched to Dukaan AI as their free Khatabook and Vyapar alternative.
        </p>
      </div>

      <div class="max-w-4xl mx-auto overflow-hidden rounded-3xl border border-forest-900/10 bg-white shadow-lg">
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead class="bg-forest-900 text-white">
              <tr>
                <th class="p-5 font-semibold leading-none">Feature</th>
                <th class="p-5 text-center font-bold text-gold-300 leading-none">Dukaan AI 🏆</th>
                <th class="p-5 text-center font-semibold leading-none">Khatabook</th>
                <th class="p-5 text-center font-semibold leading-none">Vyapar</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-forest-900/10">
              {comparison.map((row, i) => (
                <tr class={i % 2 === 1 ? 'bg-forest-50/50' : 'bg-white'}>
                  <td class="p-5 font-medium text-forest-950">{row.feature}</td>
                  <td class="p-5 text-center">
                    {row.dukaan ? <Check class="inline text-forest-600" size={20}/> : <X class="inline text-red-500" size={20}/>}
                  </td>
                  <td class="p-5 text-center">
                    {row.khatabook ? <Check class="inline text-forest-600" size={20}/> : <X class="inline text-red-500" size={20}/>}
                  </td>
                  <td class="p-5 text-center">
                    {row.vyapar ? <Check class="inline text-forest-600" size={20}/> : <X class="inline text-red-500" size={20}/>}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section-shell py-14 sm:py-20">
      <div class="mb-12 max-w-3xl mx-auto text-center">
        <h2 class="font-display text-3xl font-bold text-forest-950 sm:text-4xl">
          kirana billing app — FAQs
        </h2>
      </div>
      <div class="mx-auto max-w-3xl space-y-4">
        {faqs.map(faq => (
          <div class="panel rounded-2xl p-6">
            <h3 class="font-display text-lg font-bold text-forest-950">{faq.question}</h3>
            <p class="mt-3 text-sm leading-7 text-forest-800">{faq.answer}</p>
          </div>
        ))}
      </div>
    </section>

  </main>
  <SiteFooter />
</BaseLayout>

