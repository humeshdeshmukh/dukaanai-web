---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { site } from "../../data/site";

const title = "Terms of Service | Dukaan AI";
const description = "The terms and conditions for using the Dukaan AI shop management application and website.";
---

<BaseLayout title={title} description={description}>
  <SiteHeader />
  
  <main class="pt-32 pb-24">
    <article class="section-shell max-w-4xl">
      <header class="mb-12 border-b border-forest-100 pb-8">
        <h1 class="font-display text-4xl font-bold text-forest-950 sm:text-5xl">Terms of Service</h1>
        <p class="mt-4 text-sm text-forest-600">Last Updated: April 20, 2026</p>
      </header>
      
      <div class="prose prose-forest max-w-none space-y-8 text-forest-800">
        <section>
          <h2 class="font-display text-2xl font-bold text-forest-950">1. Acceptance of Terms</h2>
          <p class="mt-4 leading-8">
            By accessing or using the Dukaan AI application or website, you agree to be bound by these Terms of Service. If you do not agree to these terms, please do not use our services.
          </p>
        </section>

        <section>
          <h2 class="font-display text-2xl font-bold text-forest-950">2. Use of Services</h2>
          <p class="mt-4 leading-8">
            Dukaan AI provides tools for business management. You agree to use these services only for lawful business purposes and in accordance with these Terms. You are responsible for the accuracy of any data you enter into the application.
          </p>
        </section>

        <section>
          <h2 class="font-display text-2xl font-bold text-forest-950">3. User Accounts</h2>
          <p class="mt-4 leading-8">
            To use certain features, you may be required to create an account. You are responsible for maintaining the confidentiality of your account credentials and for all activities that occur under your account.
          </p>
        </section>

        <section>
          <h2 class="font-display text-2xl font-bold text-forest-950">4. Intellectual Property</h2>
          <p class="mt-4 leading-8">
            The Dukaan AI name, logo, and all related software, designs, and content are the intellectual property of Dukaan AI. You may not reproduce or distribute any part of our services without prior written permission.
          </p>
        </section>

        <section>
          <h2 class="font-display text-2xl font-bold text-forest-950">5. Limitation of Liability</h2>
          <p class="mt-4 leading-8">
            Dukaan AI is provided "as is". While we strive for 100% accuracy in our AI tools, we are not liable for any business losses, data inaccuracies, or errors resulting from the use of our application.
          </p>
        </section>

        <section>
          <h2 class="font-display text-2xl font-bold text-forest-950">6. Modifications</h2>
          <p class="mt-4 leading-8">
            We reserve the right to modify these Terms at any time. Your continued use of Dukaan AI after such changes constitutes acceptance of the new Terms.
          </p>
        </section>

        <section>
          <h2 class="font-display text-2xl font-bold text-forest-950">7. Contact Information</h2>
          <p class="mt-4 leading-8">
            For any questions regarding these Terms, please contact us at: {site.businessEmail}
          </p>
        </section>
      </div>
    </article>
  </main>

  <SiteFooter />
</BaseLayout>
