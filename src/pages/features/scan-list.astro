---
import FeatureLayout from "../../layouts/FeatureLayout.astro";

const title = "Convert Handwritten Lists to Digital | Dukaan AI";
const description = "Scan handwritten customer lists or stock notes instantly. Dukaan AI uses advanced OCR to digitize your notes and speed up your workflow.";

const benefits = [
  {
    title: "Instant List Digitization",
    text: "Tired of reading messy handwriting? Scan any note and get a clean, digital list of items and quantities instantly."
  },
  {
    title: "Error-Free Billing",
    text: "Avoid missing items from customer lists. The AI extracts every line so you can bill the entire list without double-checking."
  },
  {
    title: "Quick Share",
    text: "Convert your paper notes into digital messages and share them with staff or suppliers in seconds."
  },
  {
    title: "Archive Your Notes",
    text: "Keep a digital history of your notes for future reference. No more searching through piles of paper slips."
  }
];

const faqs = [
  {
    question: "How accurate is the handwriting recognition?",
    answer: "Our AI is extensively trained on various handwriting styles used by Indian shopkeepers and customers, providing high accuracy for diverse scripts."
  },
  {
    question: "Can it handle long lists?",
    answer: "Yes, you can scan multi-page lists or long slips. The AI will process and organize the items line by line."
  },
  {
    question: "Do I need good lighting to scan?",
    answer: "While better lighting improves results, our advanced image processing can handle typical shop lighting conditions effectively."
  }
];
---

<FeatureLayout
  title={title}
  description={description}
  featureTitle="Scan List"
  featureDescription="The bridge between paper and digital. Digitize your handwritten notes and customer lists with ease."
  imagePath="/images/scan-list.png"
  badge="List Digitization"
  benefits={benefits}
  faqs={faqs}
/>
