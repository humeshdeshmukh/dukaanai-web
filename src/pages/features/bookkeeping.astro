---
import FeatureLayout from "../../layouts/FeatureLayout.astro";

const title = "Daily Shop Bookkeeping & Profit Tracking | Dukaan AI";
const description = "Track your daily sales, expenses, and profits with AI-powered bookkeeping. Get detailed insights into your business performance with Dukaan AI.";

const benefits = [
  {
    title: "Profit & Loss Tracking",
    text: "Know exactly how much you are earning. Track your margins and identify which days or products are most profitable."
  },
  {
    title: "Insightful Business Charts",
    text: "Visualize your growth with easy-to-read charts that show your sales trends over weeks and months."
  },
  {
    title: "Digital Sales Records",
    text: "Store all your daily sales records in one organized place. No more manual ledger counting at the end of the month."
  },
  {
    title: "Simplified Expenses",
    text: "Record shop rent, electricity, and staff wages to get a true picture of your net business profit."
  }
];

const faqs = [
  {
    question: "How does Dukaan AI calculate my profit?",
    answer: "By comparing your sales price with purchase records, the AI automatically calculates gross margins and net profits for your shop."
  },
  {
    question: "Can I export my bookkeeping reports?",
    answer: "Yes, you can generate and share summary reports to review your business performance over any time period."
  },
  {
    question: "Is it suitable for a small grocery store?",
    answer: "Yes, it is specifically designed for small and medium Indian retail businesses like kirana stores, medical shops, and more."
  }
];
---

<FeatureLayout
  title={title}
  description={description}
  featureTitle="Daily Bookkeeping"
  featureDescription="Take control of your business numbers. Track sales, expenses, and growth with AI-powered insights."
  imagePath="/images/bookkeeping.png"
  badge="Profit Tracking"
  benefits={benefits}
  faqs={faqs}
/>
