---
import FeatureLayout from "../../layouts/FeatureLayout.astro";

const title = "AI Bill Scanner & Verification | Dukaan AI";
const description = "Verify wholesaler bills instantly with AI. Scan any printed or handwritten bill to extract items, prices, and quantities automatically.";

const benefits = [
  {
    title: "Instant OCR Extraction",
    text: "Point your camera at a bill and watch as Dukaan AI automatically extracts every item, quantity, and price accurately."
  },
  {
    title: "Mistake Prevention",
    text: "Compare your received items with the bill to ensure you are never overcharged or short-changed by suppliers."
  },
  {
    title: "Digital Purchase Records",
    text: "Automatically convert physical bills into digital purchase entries. No more manual data entry after a wholesale order arrival."
  },
  {
    title: "Price Monitoring",
    text: "Keep track of price changes from your suppliers over time and buy smarter to improve your margins."
  }
];

const faqs = [
  {
    question: "Does it work with handwritten bills?",
    answer: "Yes, our AI is trained to recognize various styles of handwritten bills common in Indian wholesale markets."
  },
  {
    question: "What items can it extract?",
    answer: "It can extract item names, quantities (kg, pcs, boxes), unit prices, and total bill amounts."
  },
  {
    question: "How long does it take to scan a bill?",
    answer: "Scanning and extraction usually takes just a few seconds, depending on the number of items on the bill."
  }
];
---

<FeatureLayout
  title={title}
  description={description}
  featureTitle="Bill Verification"
  featureDescription="The fastest way to record purchase bills. Let AI handle the data entry so you can focus on selling."
  imagePath="/images/bill-verification.png"
  badge="AI Scanner"
  benefits={benefits}
  faqs={faqs}
/>
