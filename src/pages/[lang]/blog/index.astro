---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import SiteHeader from "../../../components/SiteHeader.astro";
import SiteFooter from "../../../components/SiteFooter.astro";
import { getCollection } from "astro:content";
import { site } from "../../../data/site";
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";
import { languageCodes } from "../../../i18n/ui";

export function getStaticPaths() {
  return languageCodes.filter(c => c !== 'en').map(lang => ({ params: { lang } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const posts = await getCollection("blog", ({ data }) => {
  return data.lang === lang;
});

// Sort by date descending
const sortedPosts = posts.sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());
---

<BaseLayout title={`Blog | ${site.name}`} description="Expert tips and guides for Indian shopkeepers on managing credit, billing, and inventory using AI.">
  <SiteHeader />
  
  <main class="pt-24 sm:pt-32">
    <section class="section-shell pb-20">
      <div class="mb-14 max-w-3xl">
        <span class="eyebrow">{t("nav.blog") || "Blog"}</span>
        <h1 class="mt-4 font-display text-4xl font-bold text-forest-950 sm:text-5xl lg:text-6xl">
          {t("blog.indexTitle") || "Expert insights for the modern shopkeeper."}
        </h1>
        <p class="mt-6 text-lg leading-8 text-forest-800">
          {t("blog.indexDesc") || "Learn how to grow your business, compete with digital apps, and master your shop's operations with simplified AI tools."}
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
        {sortedPosts.length > 0 ? sortedPosts.map(post => (
          <article class="group panel flex flex-col overflow-hidden transition hover:border-gold-400 hover:shadow-xl">
            <a href={`/${lang}/blog/${post.slug.split('/').pop()}`} class="aspect-[16/10] overflow-hidden bg-forest-950/5">
              <img 
                src={post.data.image || "/images/hero-overview.png"} 
                alt={post.data.title} 
                class="h-full w-full object-cover transition duration-500 group-hover:scale-105" 
              />
            </a>
            <div class="flex flex-1 flex-col p-6 sm:p-8">
              <div class="mb-4 flex flex-wrap gap-2">
                {post.data.tags.slice(0, 2).map(tag => (
                  <span class="rounded-full bg-forest-100 px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-forest-700">
                    {tag}
                  </span>
                ))}
              </div>
              <h2 class="font-display text-xl font-bold text-forest-950 transition group-hover:text-gold-700">
                <a href={`/${lang}/blog/${post.slug.split('/').pop()}`}>{post.data.title}</a>
              </h2>
              <p class="mt-4 flex-1 text-sm leading-7 text-forest-800 line-clamp-3">
                {post.data.description}
              </p>
              <div class="mt-8 flex items-center justify-between border-t border-forest-900/5 pt-6">
                <time datetime={post.data.pubDate} class="text-xs font-bold uppercase tracking-widest text-forest-900/40">
                  {new Date(post.data.pubDate).toLocaleDateString(lang === 'hinglish' ? 'en-IN' : lang, { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
                <a href={`/${lang}/blog/${post.slug.split('/').pop()}`} class="text-xs font-bold uppercase tracking-widest text-forest-900 hover:text-gold-700">
                  {t("features.learnMore") || "Read More"}
                </a>
              </div>
            </div>
          </article>
        )) : (
            <div class="col-span-full py-20 text-center">
                <p class="text-forest-800/60">Coming soon in your language...</p>
                <a href="/blog" class="mt-4 inline-block text-gold-600 font-bold hover:underline">Read English Blog</a>
            </div>
        )}
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
