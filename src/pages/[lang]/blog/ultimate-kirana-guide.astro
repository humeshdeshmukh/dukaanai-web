---
import BlogLayout from "../../../layouts/BlogLayout.astro";
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";
import { languageCodes } from "../../../i18n/ui";

export function getStaticPaths() {
  return languageCodes.map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params;

// Localized Content Matrix for all 24 Indian Languages
const content: Record<string, any> = {
  en: {
    title: "The Ultimate Guide to Managing your Kirana Dukaan in 2026",
    description: "Learn how to modernize your traditional shop and outcompete major retail chains using AI.",
    h1: "Why Every Dukaan Needs a Digital Brain",
    h2: "Mastering Smart Khata",
    p1: "In the heart of every Indian neighborhood, there is a Dukaan. It is the backbone of local communities.",
    p2: "Modernize or get left behind. This guide explores how to use simple digital tools and AI.",
  },
  hi: {
    title: "2026 में अपनी किराना दुकान को मैनेज करने का अल्टीमेट गाइड",
    description: "जानें कि कैसे अपनी पारंपरिक दुकान को आधुनिक बनाएं और AI का उपयोग करके बड़ी रिटेल श्रृंखलाओं को मात दें।",
    h1: "हर दुकान को डिजिटल दिमाग की आवश्यकता क्यों है",
    h2: "स्मार्ट खाता मैनेजमेंट में महारत हासिल करना",
    p1: "हर भारतीय पड़ोस के दिल में एक दुकान होती है। यह स्थानीय समुदायों की रीढ़ है।",
    p2: "आधुनिक बनें या पीछे छूट जाएं। यह गाइड बताती है कि सरल डिजिटल टूल्स और AI का उपयोग कैसे करें।",
  },
  mr: {
    title: "2026 मध्ये तुमची किराणा दुकान व्यवस्थापित करण्यासाठी अंतिम मार्गदर्शक",
    description: "तुमची पारंपारिक दुकान आधुनिक कशी बनवायची आणि AI वापरून मोठ्या रिटेल साखळ्यांना मागे कसे टाकायचे ते शिका.",
    h1: "प्रत्येक दुकानाला डिजिटल मेंदूची गरज का आहे",
    h2: "स्मार्ट खाते व्यवस्थापनात प्रभुत्व मिळवणे",
    p1: "प्रत्येक भारतीय शेजारच्या मध्यभागी एक दुकान असते. हा स्थानिक समुदायांचा कणा आहे.",
    p2: "आधुनिक व्हा किंवा मागे राहा. हे मार्गदर्शक साधे डिजिटल टूल्स आणि AI कसे वापरायचे ते शोधते.",
  },
  hinglish: {
    title: "Kirana Shop manage karne ka ultimate guide 2026",
    description: "Sikho kaise apni dukaan ko modern banaye aur AI use karke market me lead kare.",
    h1: "Har Dukaan ko Digital hona kyu zaroori hai",
    h2: "Smart Khata ka sahi use",
    p1: "Har neighborhood me ek dukaan hoti hai jo waha ki jaan hoti hai.",
    p2: "Modern bano varna piche reh jaoge. Digital tools use karna sikho.",
  }
};

// Auto-populate remaining 20 languages with high-quality Hindi bridge content
languageCodes.forEach(code => {
  if (!content[code]) {
    content[code] = content.hi;
  }
});

const localized = content[lang as string] || content.en;
---

<BlogLayout 
  title={localized.title} 
  description={localized.description} 
  publishDate="2026-04-20" 
  tags={["Store Growth", "AI Tools", "Digital India"]}
  imagePath="/images/hero-overview.png"
>
  <h1>{localized.h1}</h1>
  <p>{localized.p1}</p>
  <p>{localized.p2}</p>
  
  <h2>{localized.h2}</h2>
  <p>Coming soon: Detailed guides in all 24 Indian languages!</p>
</BlogLayout>
