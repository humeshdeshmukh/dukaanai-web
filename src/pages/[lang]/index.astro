---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import HeroSection from "../../components/HeroSection.astro";
import FeatureGrid from "../../components/FeatureGrid.astro";
import TechStackSection from "../../components/TechStackSection.astro";
import PerformanceSection from "../../components/PerformanceSection.astro";
import DeploySection from "../../components/DeploySection.astro";
import FaqSection from "../../components/FaqSection.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { getFeatures, getHighlights, getFaqs, site } from "../../data/site";
import { ui } from "../../i18n/ui";
import { useTranslations } from "../../i18n/utils";

export function getStaticPaths() {
  return [
    { params: { lang: "en" } },
    { params: { lang: "hi" } },
    { params: { lang: "mr" } },
    { params: { lang: "bn" } },
    { params: { lang: "pa" } },
    { params: { lang: "gu" } },
    { params: { lang: "ta" } },
    { params: { lang: "te" } },
    { params: { lang: "kn" } },
    { params: { lang: "ml" } },
    { params: { lang: "or" } },
    { params: { lang: "as" } },
    { params: { lang: "mai" } },
    { params: { lang: "sat" } },
    { params: { lang: "ks" } },
    { params: { lang: "doi" } },
    { params: { lang: "sd" } },
    { params: { lang: "kok" } },
    { params: { lang: "mni" } },
    { params: { lang: "ne" } },
    { params: { lang: "sa" } },
    { params: { lang: "ur" } },
    { params: { lang: "hinglish" } },
  ];
}

const { lang } = Astro.params;
const t = useTranslations(lang as any);
const localizedFeatures = getFeatures(lang);
const localizedHighlights = getHighlights(lang);
const localizedFaqs = getFaqs(lang);
---

<BaseLayout>
  <SiteHeader />
  <main>
    <HeroSection />
    <FeatureGrid items={localizedFeatures} />
    <TechStackSection items={localizedHighlights} />
    <PerformanceSection />
    <FaqSection items={localizedFaqs} />
    <DeploySection />

    <section class="section-shell pb-16 pt-4 sm:pb-24">
      <div class="panel overflow-hidden bg-gradient-to-r from-forest-900 via-forest-800 to-forest-700 px-5 py-8 text-white sm:px-8 sm:py-10">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
          <div class="max-w-2xl">
            <p class="text-sm font-bold uppercase tracking-[0.2em] text-gold-200">{site.name}</p>
            <h2 class="mt-3 font-display text-3xl font-bold sm:text-4xl">
              Business tools for billing, credit management, and store operations.
            </h2>
            <p class="mt-4 text-base leading-8 text-white/85">
              Contact our team or visit the Play Store to learn more about Dukaan AI.
            </p>
          </div>

          <div class="flex flex-col gap-3 sm:min-w-[220px]">
            <a
              href={`mailto:${site.businessEmail}`}
              class="inline-flex items-center justify-center rounded-full bg-gold-300 px-6 py-3 text-sm font-bold text-forest-950 transition hover:bg-gold-200"
            >
              Contact Dukaan AI
            </a>
            <a
              href={site.playStoreUrl}
              class="inline-flex items-center justify-center rounded-full border border-white/20 bg-white/10 px-6 py-3 text-sm font-bold text-white transition hover:bg-white/20"
            >
              View Play Store App
            </a>
          </div>
        </div>
      </div>
    </section>
    <SiteFooter />
  </main>
</BaseLayout>
