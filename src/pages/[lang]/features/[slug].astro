---
import FeatureLayout from "../../../layouts/FeatureLayout.astro";
import { getFeatures, site } from "../../../data/site";
import { languageCodes } from "../../../i18n/ui";

export function getStaticPaths() {
  const slugs = ["bookkeeping", "smart-khata", "voice-billing", "bill-verification", "orders-management", "scan-list"];
  
  return languageCodes.flatMap(lang => 
    slugs.map(slug => ({ params: { lang, slug } }))
  );
}

const { lang, slug } = Astro.params;

// Get the specific feature data for this lang
const localizedFeatures = getFeatures(lang as string);
const feature = localizedFeatures.find(f => f.slug === slug) || getFeatures("en").find(f => f.slug === slug);

if (!feature) {
  return Astro.redirect("/404");
}

// In a real app, you'd have more granular benefits/faqs per lang.
// For now, we'll use placeholers or shared context if not explicitly in site.ts features.
const title = `${feature.title} | ${site.name}`;
const description = feature.description;

// Use feature-specific content with global fallbacks
import { getBenefits, getFaqs } from "../../../data/site";
const featureBenefits = feature.benefits || getBenefits(lang);
const featureFaqs = feature.faqs || getFaqs(lang);
const featureSteps = (feature as any).steps || [];
---

<FeatureLayout
  title={title}
  description={description}
  featureTitle={feature.title}
  featureDescription={feature.description}
  imagePath={feature.image}
  badge={feature.badge}
  benefits={featureBenefits}
  faqs={featureFaqs}
  steps={featureSteps}
/>
