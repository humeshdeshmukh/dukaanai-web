---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import type { FeatureItem } from "../data/site";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

interface Props {
  items: FeatureItem[];
}

const { items } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const getLink = (path: string) => {
  if (lang === 'en') return path;
  return `/${lang}${path === '/' ? '' : path}`;
};

// Import all images from assets
const images = import.meta.glob<{ default: ImageMetadata }>("/src/assets/images/*.{jpeg,jpg,png,gif}");

---

<section id="features" class="section-shell py-14 sm:py-20">
  <div class="mb-8 max-w-3xl space-y-4">
    <span class="eyebrow">Core features</span>
    <h2 class="font-display text-3xl font-bold text-forest-950 sm:text-4xl">
      Everything your business needs in one Dukaan AI app
    </h2>
    <p class="text-base leading-8 text-forest-800">
      From voice billing to smart khata and AI bill scanning, Dukaan AI helps shop owners save time, reduce manual work, and run their business better.
    </p>
  </div>

  <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
    {
      items.map((item, index) => {
        // Resolve the asset path from the feature image string
        // item.image looks like "/images/bookkeeping.png"
        // we want to match it against "/src/assets/images/bookkeeping.png"
        const assetPath = `/src/assets${item.image}`;
        const imageAsset = images[assetPath];

        return (
          <article class="group panel relative overflow-hidden transition hover:border-gold-400 hover:shadow-xl">
            <div class="aspect-[4/5] overflow-hidden bg-forest-950/5">
              {imageAsset ? (
                <Image
                  src={imageAsset()}
                  alt={`Dukaan AI ${item.title} feature: ${item.description}`}
                  width={430}
                  height={538}
                  class="feature-image transition duration-500 group-hover:scale-105"
                  loading={index < 2 ? "eager" : "lazy"}
                  fetchpriority="auto"
                  widths={[430, 800, 1200]}
                  sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 430px"
                  decoding="async"
                  quality={70}
                />
              ) : (
                <img
                  src={item.image}
                  alt={`Dukaan AI ${item.title} feature: ${item.description}`}
                  class="feature-image"
                />
              )}
            </div>
            <div class="space-y-4 px-5 py-6 sm:px-6">
              <span class="inline-flex rounded-full bg-forest-100 px-3 py-1 text-xs font-bold uppercase tracking-[0.18em] text-forest-700">
                {item.badge}
              </span>
              <h3 class="font-display text-2xl font-bold text-forest-950">{item.title}</h3>
              <p class="text-sm leading-7 text-forest-800">{item.description}</p>
              
              <div class="pt-2">
                <a 
                  href={getLink(`/features/${item.slug}`)} 
                  class="inline-flex items-center gap-2 text-sm font-bold text-forest-800 transition hover:text-gold-700"
                >
                  Learn how it works
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition group-hover:translate-x-1"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                </a>
              </div>
            </div>
            
            {/* Make the whole card clickable for better UX, but keeping the link for accessibility/SEO */}
            <a href={getLink(`/features/${item.slug}`)} class="absolute inset-0 z-10" aria-label={`View details about ${item.title}`}></a>
          </article>
        );
      })
    }
  </div>
</section>
