---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

interface Props {
  items: { question: string; answer: string }[];
}

const { items } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="faq" class="section-shell py-14 sm:py-20">
  <div class="panel overflow-hidden px-5 py-6 sm:px-8 sm:py-8">
    <div class="max-w-3xl space-y-4">
      <span class="eyebrow">{t("nav.faq")}</span>
      <h2 class="font-display text-3xl font-bold text-forest-950 sm:text-4xl">
        {t("feature.faqTitle")}
      </h2>
      <p class="text-base leading-8 text-forest-800">
        {t("feature.faqEyebrow")} — {t("feature.ctaDesc")}
      </p>
    </div>

    <div class="mt-8 grid gap-4">
      {
        items.map((item, index) => (
          <details class="accordion-card reveal-up" style={`--reveal-delay: ${0.02 + index * 0.06}s;`}>
            <summary class="accordion-summary">
              <h3 class="pr-4 text-lg font-bold text-forest-950">{item.question}</h3>
              <span class="accordion-plus" aria-hidden="true"></span>
            </summary>
            <div class="accordion-body">
              <div class="accordion-body-inner">
                <p class="text-sm leading-7 text-forest-800">{item.answer}</p>
              </div>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
