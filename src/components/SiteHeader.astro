import { Menu, Smartphone, X, Globe } from "@lucide/astro";
import { site } from "../data/site";
import { Image } from "astro:assets";
import dukaanLogo from "../assets/images/dukaan-logo.jpeg";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { languages } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const getLink = (path: string) => {
  if (lang === 'en') return path;
  return `/${lang}${path === '/' ? '' : path}`;
};
---

<header class="section-shell pt-5 sm:pt-7">
  <div class="panel px-4 py-3 sm:px-6">
    <div class="flex items-center justify-between">
      <a href={getLink("/")} class="flex items-center gap-3">
        <Image
          src={dukaanLogo}
          alt="Dukaan AI logo"
          width={64}
          height={64}
          class="h-14 w-14 rounded-2xl object-cover ring-1 ring-forest-900/10"
          loading="eager"
        />
        <div>
          <p class="font-display text-2xl font-bold tracking-tight text-forest-900">{site.name}</p>
          <p class="text-sm text-forest-700">Smart khata, billing and business insights</p>
        </div>
      </a>

      <nav class="hidden items-center gap-6 text-sm font-semibold text-forest-800 md:flex">
        <a href={getLink("/#features")} class="transition hover:text-gold-600">{t("nav.features")}</a>
        <a href={getLink("/blog")} class="transition hover:text-gold-600">{t("nav.blog")}</a>
        <a href={getLink("/#about")} class="transition hover:text-gold-600">{t("nav.about")}</a>
        <a href={getLink("/#benefits")} class="transition hover:text-gold-600">{t("nav.benefits")}</a>
        <a href={getLink("/#faq")} class="transition hover:text-gold-600">{t("nav.faq")}</a>
      </nav>

      <div class="flex items-center gap-2">
        <!-- Language Selector -->
        <div class="relative group mr-2">
          <button class="flex items-center gap-1.5 rounded-full border border-forest-900/10 bg-white/80 px-3 py-1.5 text-xs font-bold text-forest-800 transition hover:border-gold-400">
            <Globe size={14} class="text-gold-600" />
            <span class="uppercase">{lang}</span>
          </button>
          <div class="absolute right-0 top-full mt-2 hidden w-40 origin-top-right rounded-2xl border border-forest-900/10 bg-white p-2 shadow-2xl group-hover:block animate-in fade-in zoom-in-95 duration-200">
            <div class="grid gap-1 max-h-64 overflow-y-auto custom-scrollbar">
              {Object.entries(languages).map(([code, label]) => (
                <a 
                  href={code === 'en' ? '/' : `/${code}/`}
                  class={`block rounded-xl px-3 py-2 text-xs font-medium transition hover:bg-forest-50 ${lang === code ? 'bg-gold-50 text-gold-700' : 'text-forest-800'}`}
                >
                  {label}
                </a>
              ))}
            </div>
          </div>
        </div>

        <a
          href={site.playStoreUrl}
          target="_blank"
          rel="noreferrer"
          class="hidden items-center gap-2 rounded-full bg-forest-800 px-4 py-2 text-sm font-semibold text-white shadow-glow transition hover:bg-forest-700 sm:inline-flex"
        >
          <Smartphone size={16} />
          {t("cta.getApp")}
        </a>
        <button
          type="button"
          class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-forest-900/10 bg-white/80 text-forest-900 md:hidden"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-nav"
          data-menu-toggle
        >
          <Menu size={18} data-menu-icon="open" />
          <X size={18} class="hidden" data-menu-icon="close" />
        </button>
      </div>
    </div>

    <div
      id="mobile-nav"
      class="hidden border-t border-forest-900/10 pt-4 md:hidden"
      data-mobile-menu
    >
      <nav class="flex flex-col gap-2 text-sm font-semibold text-forest-800">
        <a href={getLink("/#features")} class="rounded-2xl px-3 py-3 transition hover:bg-forest-50" data-mobile-link>{t("nav.features")}</a>
        <a href={getLink("/blog")} class="rounded-2xl px-3 py-3 transition hover:bg-forest-50" data-mobile-link>{t("nav.blog")}</a>
        <a href={getLink("/#about")} class="rounded-2xl px-3 py-3 transition hover:bg-forest-50" data-mobile-link>{t("nav.about")}</a>
        <a href={getLink("/#benefits")} class="rounded-2xl px-3 py-3 transition hover:bg-forest-50" data-mobile-link>{t("nav.benefits")}</a>
        <a href={getLink("/#faq")} class="rounded-2xl px-3 py-3 transition hover:bg-forest-50" data-mobile-link>{t("nav.faq")}</a>
      </nav>

      <a
        href={site.playStoreUrl}
        target="_blank"
        rel="noreferrer"
        class="mt-4 inline-flex w-full items-center justify-center gap-2 rounded-full bg-forest-800 px-5 py-3 text-sm font-semibold text-white shadow-glow transition hover:bg-forest-700"
        data-mobile-link
      >
        <Smartphone size={16} />
        {t("cta.getApp")}
      </a>
    </div>
  </div>
</header>

<script>
  const initMobileMenu = () => {
    const toggle = document.querySelector("[data-menu-toggle]");
    const menu = document.querySelector("[data-mobile-menu]");
    if (!(toggle instanceof HTMLButtonElement) || !(menu instanceof HTMLElement)) return;

    const openIcon = toggle.querySelector('[data-menu-icon="open"]');
    const closeIcon = toggle.querySelector('[data-menu-icon="close"]');
    const links = menu.querySelectorAll("[data-mobile-link]");

    const setOpen = (isOpen) => {
      menu.classList.toggle("hidden", !isOpen);
      toggle.setAttribute("aria-expanded", String(isOpen));
      openIcon?.classList.toggle("hidden", isOpen);
      closeIcon?.classList.toggle("hidden", !isOpen);
    };

    setOpen(false);

    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      setOpen(!isOpen);
    });

    links.forEach((link) => {
      link.addEventListener("click", () => setOpen(false));
    });

    const mql = window.matchMedia("(min-width: 768px)");
    mql.addEventListener("change", (e) => {
      if (e.matches) setOpen(false);
    });
  };

  initMobileMenu();
  document.addEventListener("astro:page-load", initMobileMenu);
</script>
