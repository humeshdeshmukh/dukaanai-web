---
import { getLangFromUrl, useTranslations } from "../i18n/utils";

interface Props {
  items: { title: string; text: string }[];
}

const { items } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="benefits" class="section-shell py-14 sm:py-20">
  <div class="panel overflow-hidden">
    <div class="grid gap-8 px-5 py-6 sm:px-8 sm:py-8 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="space-y-4">
        <span class="eyebrow">{t("nav.benefits")}</span>
        <h2 class="font-display text-3xl font-bold text-forest-950 sm:text-4xl">
          {t("hero.title1")} — {t("nav.benefits")}
        </h2>
        <p class="text-base leading-8 text-forest-800">
          {t("hero.description")}
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {
          items.map((item, index) => (
            <details class="accordion-card reveal-up" style={`--reveal-delay: ${0.02 + index * 0.06}s;`}>
              <summary class="accordion-summary">
                <h3 class="font-display text-xl font-bold text-forest-950">{item.title}</h3>
                <span class="accordion-plus" aria-hidden="true"></span>
              </summary>
              <div class="accordion-body">
                <div class="accordion-body-inner">
                  <p class="text-sm leading-7 text-forest-800">{item.text}</p>
                </div>
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </div>
</section>
