---
import { benefits } from "../data/site";

const items = benefits;
---

<section id="benefits" class="section-shell py-14 sm:py-20">
  <div class="panel overflow-hidden">
    <div class="grid gap-8 px-5 py-6 sm:px-8 sm:py-8 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="space-y-4">
        <span class="eyebrow">Why businesses choose Dukaan AI</span>
        <h2 class="font-display text-3xl font-bold text-forest-950 sm:text-4xl">
          Replace manual work with faster, smarter daily operations
        </h2>
        <p class="text-base leading-8 text-forest-800">
          Dukaan AI is built to reduce typing, speed up billing, improve credit tracking, and help business owners make better stocking and profit decisions.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {
          items.map((item) => (
            <div class="rounded-[24px] border border-forest-900/10 bg-white/80 px-5 py-5">
              <h3 class="font-display text-xl font-bold text-forest-950">{item.title}</h3>
              <p class="mt-3 text-sm leading-7 text-forest-800">{item.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
