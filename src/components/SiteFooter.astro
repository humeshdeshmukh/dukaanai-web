---
import { site } from "../data/site";
const currentYear = new Date().getFullYear();

const footerLinks = [
  { name: "Voice Billing", href: "/features/voice-billing" },
  { name: "Smart Khata", href: "/features/smart-khata" },
  { name: "Daily Bookkeeping", href: "/features/bookkeeping" },
  { name: "Bill Verification", href: "/features/bill-verification" },
  { name: "Orders Management", href: "/features/orders-management" },
  { name: "Scan List", href: "/features/scan-list" }
];

const supportLinks = [
  { name: "Blog & Guides", href: "/blog" },
  { name: "Kirana Guide", href: "/blog/ultimate-kirana-guide" },
  { name: "FAQ", href: "/#faq" }
];

const legalLinks = [
  { name: "Privacy Policy", href: "/legal/privacy" },
  { name: "Terms of Service", href: "/legal/terms" },
  { name: "Contact", href: `mailto:${site.businessEmail}` }
];
---

<footer class="section-shell py-16 sm:py-20">
  <div class="grid gap-12 border-t border-forest-900/10 pt-12 lg:grid-cols-12 lg:gap-8">
    <div class="lg:col-span-4">
      <div class="flex items-center gap-3">
        <div class="h-2 w-2 rounded-full bg-gold-500"></div>
        <p class="text-lg font-bold tracking-tight text-forest-950">
          {site.name}
        </p>
      </div>
      <p class="mt-4 max-w-xs text-sm leading-7 text-forest-700">
        AI-powered business assistant for Indian shopkeepers. Manage billing, khata, and inventory with ease.
      </p>
      <div class="mt-6">
        <a href={site.playStoreUrl} target="_blank" rel="noreferrer" class="inline-flex items-center justify-center rounded-full bg-forest-800 px-6 py-3 text-xs font-bold uppercase tracking-widest text-white transition hover:bg-forest-700">
          Get the app
        </a>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-8 sm:grid-cols-3 lg:col-span-8">
      <div class="col-span-2 sm:col-span-2">
        <p class="text-xs font-bold uppercase tracking-widest text-forest-950/40">Features</p>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          {
            footerLinks.map((link) => (
              <a href={link.href} class="text-sm font-medium text-forest-800 transition hover:text-gold-700">
                {link.name}
              </a>
            ))
          }
        </div>
      </div>

      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-forest-950/40">Resources</p>
        <div class="mt-6 grid gap-4">
          {
            supportLinks.map((link) => (
              <a href={link.href} class="text-sm font-medium text-forest-800 transition hover:text-gold-700">
                {link.name}
              </a>
            ))
          }
        </div>
      </div>

      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-forest-950/40">Company</p>
        <div class="mt-6 grid gap-4">
          {
            legalLinks.map((link) => (
              <a href={link.href} class="text-sm font-medium text-forest-800 transition hover:text-gold-700">
                {link.name}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <div class="mt-16 border-t border-forest-100 pt-8 text-center sm:text-left">
    <p class="text-[10px] uppercase tracking-[0.2em] text-forest-900/40">
      &copy; {currentYear} {site.name}. All rights reserved. <span class="mx-2">|</span> Made for Bharat.
    </p>
  </div>
</footer>
