---
import { site } from "../data/site";
const currentYear = new Date().getFullYear();

const footerLinks = [
  { name: "Play Store", href: site.playStoreUrl },
  { name: "Contact", href: `mailto:${site.businessEmail}` },
  { name: "Privacy", href: "#" }
];
---

<footer class="section-shell py-12 sm:py-16">
  <div class="flex flex-col items-center justify-between border-t border-forest-900/10 pt-8 sm:flex-row">
    <div class="flex items-center gap-3">
      <div class="h-2 w-2 rounded-full bg-gold-500"></div>
      <p class="text-sm font-bold tracking-tight text-forest-950">
        {site.name} <span class="mx-1 text-forest-900/30">|</span> <span class="font-medium text-forest-700">Digital ledger for Bharat</span>
      </p>
    </div>

    <div class="mt-6 flex items-center gap-8 sm:mt-0">
      {
        footerLinks.map((link) => (
          <a href={link.href} class="text-xs font-bold uppercase tracking-widest text-forest-900/60 transition hover:text-forest-950">
            {link.name}
          </a>
        ))
      }
    </div>
  </div>

  <div class="mt-8 text-center sm:text-left">
    <p class="text-[10px] uppercase tracking-[0.2em] text-forest-900/40">
      &copy; {currentYear} {site.name}. All rights reserved.
    </p>
  </div>
</footer>
