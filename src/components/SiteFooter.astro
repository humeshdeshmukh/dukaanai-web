---
import { site, getFeatures } from "../data/site";
import { languages } from "../i18n/ui";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

import { Youtube, Instagram, Linkedin, Smartphone } from "@lucide/astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const socialIcons = [
  { name: "YouTube", href: site.socialLinks.youtube, icon: Youtube },
  { name: "Instagram", href: site.socialLinks.instagram, icon: Instagram },
  { name: "LinkedIn", href: site.socialLinks.linkedin, icon: Linkedin },
];

const getLink = (path: string) => {
  if (lang === 'en') return path;
  return `/${lang}${path === '/' ? '' : path}`;
};

const currentYear = new Date().getFullYear();
const activeFeatures = getFeatures(lang);

const supportLinks = [
  { name: t("nav.features"), href: getLink("/#features") },
  { name: t("nav.howItWorks"), href: getLink("/#how-it-works") },
  { name: t("nav.faq"), href: getLink("/#faq") },
  { name: t("nav.contact"), href: "mailto:hello@dukaanai.co.in" },
];

const legalLinks = [
  { name: t("footer.privacy"), href: getLink("/legal/privacy") },
  { name: t("footer.terms"), href: getLink("/legal/terms") },
];
---

<footer class="section-shell py-16 sm:py-20">
  <div class="grid gap-12 border-t border-forest-900/10 pt-12 lg:grid-cols-12 lg:gap-8">
    <div class="lg:col-span-4">
      <div class="flex items-center gap-3">
        <div class="h-2 w-2 rounded-full bg-gold-500"></div>
        <p class="text-lg font-bold tracking-tight text-forest-950">
          {site.name}
        </p>
      </div>
      <p class="mt-4 max-w-xs text-sm leading-7 text-forest-700">
        {t("footer.tagline")}
      </p>
      <div class="mt-6 flex flex-wrap items-center gap-4">
        <a href={site.socialLinks.playStore} target="_blank" rel="noreferrer" class="inline-flex items-center justify-center gap-2 rounded-full bg-forest-800 px-6 py-3 text-xs font-bold uppercase tracking-widest text-white transition hover:bg-forest-700">
          <Smartphone size={14} />
          {t("footer.getApp")}
        </a>
        <div class="flex items-center gap-2">
          {socialIcons.map((social) => (
            <a 
              href={social.href} 
              target="_blank" 
              rel="noreferrer" 
              class="flex h-10 w-10 items-center justify-center rounded-full border border-forest-900/10 bg-white/80 text-forest-800 transition hover:border-gold-400 hover:text-gold-700 shadow-sm" 
              aria-label={social.name}
            >
              <social.icon size={18} />
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="grid grid-cols-2 gap-8 sm:grid-cols-3 lg:col-span-8">
      <div class="col-span-2 sm:col-span-2">
        <p class="text-xs font-bold uppercase tracking-widest text-forest-950/40">{t("nav.features")}</p>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          {
            activeFeatures.map((f) => (
              <a href={getLink(`/features/${f.slug}`)} class="text-sm font-medium text-forest-800 transition hover:text-gold-700">
                {f.title}
              </a>
            ))
          }
        </div>
      </div>

      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-forest-950/40">{t("footer.resources")}</p>
        <div class="mt-6 grid gap-4">
          {
            supportLinks.map((link) => (
              <a href={link.href} class="text-sm font-medium text-forest-800 transition hover:text-gold-700">
                {link.name}
              </a>
            ))
          }
        </div>
      </div>

      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-forest-950/40">{t("footer.company")}</p>
        <div class="mt-6 grid gap-4">
          {
            legalLinks.map((link) => (
              <a href={link.href} class="text-sm font-medium text-forest-800 transition hover:text-gold-700">
                {link.name}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <div class="mt-16 border-t border-forest-100 pt-12">
    <p class="text-xs font-bold uppercase tracking-widest text-forest-950/40">Available Languages</p>
    <div class="mt-8 grid grid-cols-2 gap-x-4 gap-y-4 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-8">
      {
        Object.entries(languages).map(([code, name]) => (
          <a
            href={code === 'en' ? '/' : `/${code}/`}
            class="text-[13px] font-medium text-forest-700 transition hover:text-gold-700"
          >
            {name}
          </a>
        ))
      }
    </div>
  </div>

  <div class="mt-16 border-t border-forest-100 pt-8 text-center sm:text-left">
    <p class="text-[10px] uppercase tracking-[0.2em] text-forest-900/40">
      &copy; {currentYear} {site.name}. All rights reserved. <span class="mx-2">|</span> {t("footer.madeForBharat")}
    </p>
  </div>
</footer>
