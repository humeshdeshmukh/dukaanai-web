---
import { site } from "../data/site";
import { ArrowUpRight, Github, Mail, Smartphone, Twitter } from "@lucide/astro";

const currentYear = new Date().getFullYear();

const navLinks = [
  { name: "Home", href: "#top" },
  { name: "Features", href: "#features" },
  { name: "About", href: "#about" },
  { name: "FAQ", href: "#faq" }
];
---

<footer class="section-shell pb-10 pt-16 sm:pb-12 sm:pt-20">
  <div class="panel border-forest-900/10 bg-forest-950 px-6 py-12 text-white sm:px-10 sm:py-16">
    <div class="grid gap-12 lg:grid-cols-[1.2fr_1fr]">
      <div class="space-y-8">
        <div>
          <div class="flex items-center gap-2.5">
            <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gold-400">
               <Smartphone class="text-forest-950" size={20} />
            </div>
            <span class="font-display text-2xl font-bold tracking-tight text-white">{site.name}</span>
          </div>
          <p class="mt-5 max-w-sm text-base leading-7 text-white/70">
            Empowering Indian shopkeepers with AI-powered billing, bookkeeping, and store management tools built For Bharat.
          </p>
        </div>

        <div class="flex flex-wrap gap-4">
          <a
            href={site.playStoreUrl}
            class="inline-flex items-center justify-center gap-2 rounded-full bg-white px-5 py-2.5 text-sm font-bold text-forest-950 transition hover:bg-gold-300"
          >
            Play Store App
            <ArrowUpRight size={16} />
          </a>
          <a
            href={`mailto:${site.businessEmail}`}
            class="inline-flex items-center justify-center gap-2 rounded-full border border-white/20 bg-white/5 px-5 py-2.5 text-sm font-bold text-white transition hover:bg-white/10"
          >
            Contact Email
            <Mail size={16} />
          </a>
        </div>
      </div>

      <div class="grid gap-10 sm:grid-cols-2">
        <div class="space-y-5">
          <h4 class="text-xs font-bold uppercase tracking-[0.2em] text-gold-300">Fast Navigation</h4>
          <ul class="space-y-3">
            {
              navLinks.map((link) => (
                <li>
                  <a href={link.href} class="text-base text-white/70 transition hover:text-white">
                    {link.name}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="space-y-5">
          <h4 class="text-xs font-bold uppercase tracking-[0.2em] text-gold-300">Support & Feedback</h4>
          <p class="text-sm leading-6 text-white/60">
            For business inquiries or feature requests, please reach out to our official email.
          </p>
          <a href={`mailto:${site.businessEmail}`} class="group inline-flex items-center gap-2 text-sm font-bold text-white transition hover:text-gold-200">
            {site.businessEmail}
            <ArrowUpRight size={14} class="transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
          </a>
        </div>
      </div>
    </div>

    <hr class="mt-16 border-white/10" />

    <div class="mt-10 flex flex-col items-center justify-between gap-6 sm:flex-row">
      <p class="text-sm text-white/50">
        &copy; {currentYear} {site.name}. All rights reserved. Made for Indian Retailers.
      </p>

      <div class="flex items-center gap-5 text-white/40">
         <span class="text-xs uppercase tracking-widest">v1.2.0</span>
         <div class="h-4 w-px bg-white/10"></div>
         <p class="text-xs">Digital ledger for Bharat</p>
      </div>
    </div>
  </div>
</footer>
