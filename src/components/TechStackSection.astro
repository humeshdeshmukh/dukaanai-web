---
import type { HighlightItem } from "../data/site";
import { Building2, Languages, ShieldCheck, Wallet } from "@lucide/astro";

interface Props {
  items: HighlightItem[];
}

const { items } = Astro.props;
---

<section id="about" class="section-shell py-14 sm:py-20">
  <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr]">
    <div class="space-y-5">
      <span class="eyebrow">About Dukaan AI</span>
      <h2 class="font-display text-3xl font-bold text-forest-950 sm:text-4xl">
        Built for Indian retailers who want a smarter way to manage their shop
      </h2>
      <p class="text-base leading-8 text-forest-800">
        Dukaan AI is more than a digital register. It is a business assistant designed to help local stores handle billing, udhaar, purchase records, orders, and decision-making through simple voice-first workflows.
      </p>

      <div class="grid gap-3 sm:grid-cols-2">
        <div class="panel flex gap-3 px-4 py-4">
          <Building2 class="mt-0.5 text-gold-600" size={18} />
          <div>
            <p class="text-sm font-bold text-forest-950">For kirana and wholesale</p>
            <p class="text-sm text-forest-700">Built around real daily store workflows, not generic accounting screens.</p>
          </div>
        </div>
        <div class="panel flex gap-3 px-4 py-4">
          <ShieldCheck class="mt-0.5 text-gold-600" size={18} />
          <div>
            <p class="text-sm font-bold text-forest-950">Secure records</p>
            <p class="text-sm text-forest-700">Business data is handled with privacy and trust in mind.</p>
          </div>
        </div>
        <div class="panel flex gap-3 px-4 py-4">
          <Languages class="mt-0.5 text-gold-600" size={18} />
          <div>
            <p class="text-sm font-bold text-forest-950">Regional language support</p>
            <p class="text-sm text-forest-700">Designed for Indian business owners who want to work in their own language.</p>
          </div>
        </div>
        <div class="panel flex gap-3 px-4 py-4">
          <Wallet class="mt-0.5 text-gold-600" size={18} />
          <div>
            <p class="text-sm font-bold text-forest-950">Faster collections and billing</p>
            <p class="text-sm text-forest-700">Save time on credit follow-up, bills, and supplier orders every day.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="panel overflow-hidden">
      <div class="grid-overlay grid gap-px bg-forest-900/10 p-px sm:grid-cols-2">
        {
          items.map((item) => (
            <div class="bg-white/90 px-5 py-5 sm:px-6">
              <p class="text-xs font-bold uppercase tracking-[0.2em] text-gold-700">{item.type}</p>
              <h3 class="mt-2 font-display text-2xl font-bold text-forest-950">{item.name}</h3>
              <p class="mt-3 text-sm leading-7 text-forest-800">{item.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
