---
import type { HighlightItem } from "../data/site";
import { Building2, Languages, ShieldCheck, Wallet } from "@lucide/astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";

interface Props {
  items: HighlightItem[];
}

const { items } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="about" class="section-shell py-14 sm:py-20">
  <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr]">
    <div class="space-y-5">
      <span class="eyebrow">{t("about.eyebrow")}</span>
      <h2 class="font-display text-3xl font-bold text-forest-950 sm:text-4xl">
        {t("about.title")}
      </h2>
      <p class="text-base leading-8 text-forest-800">
        {t("about.description")}
      </p>

      <div class="grid gap-3 sm:grid-cols-2">
        <div class="panel flex gap-3 px-4 py-4 reveal-up" style="--reveal-delay: 0.02s;">
          <Building2 class="mt-0.5 text-gold-600" size={18} />
          <div>
            <p class="text-sm font-bold text-forest-950">{t("about.f1.title")}</p>
            <p class="text-sm text-forest-700">{t("about.f1.desc")}</p>
          </div>
        </div>
        <div class="panel flex gap-3 px-4 py-4 reveal-up" style="--reveal-delay: 0.08s;">
          <ShieldCheck class="mt-0.5 text-gold-600" size={18} />
          <div>
            <p class="text-sm font-bold text-forest-950">{t("about.f2.title")}</p>
            <p class="text-sm text-forest-700">{t("about.f2.desc")}</p>
          </div>
        </div>
        <div class="panel flex gap-3 px-4 py-4 reveal-up" style="--reveal-delay: 0.14s;">
          <Languages class="mt-0.5 text-gold-600" size={18} />
          <div>
            <p class="text-sm font-bold text-forest-950">{t("about.f3.title")}</p>
            <p class="text-sm text-forest-700">{t("about.f3.desc")}</p>
          </div>
        </div>
        <div class="panel flex gap-3 px-4 py-4 reveal-up" style="--reveal-delay: 0.2s;">
          <Wallet class="mt-0.5 text-gold-600" size={18} />
          <div>
            <p class="text-sm font-bold text-forest-950">{t("about.f4.title")}</p>
            <p class="text-sm text-forest-700">{t("about.f4.desc")}</p>
          </div>
        </div>
      </div>
    </div>

    <div class="panel overflow-hidden">
      <div class="grid gap-3 bg-transparent p-4 sm:grid-cols-2 sm:p-5">
        {
          items.map((item, index) => (
            <details class="accordion-card reveal-up" style={`--reveal-delay: ${0.04 + index * 0.06}s;`}>
              <summary class="accordion-summary">
                <div>
                  <p class="text-xs font-bold uppercase tracking-[0.2em] text-gold-700">{item.type}</p>
                  <h3 class="mt-2 font-display text-xl font-bold text-forest-950 sm:text-2xl">{item.name}</h3>
                </div>
                <span class="accordion-plus" aria-hidden="true"></span>
              </summary>
              <div class="accordion-body">
                <div class="accordion-body-inner">
                  <p class="text-sm leading-7 text-forest-800">{item.description}</p>
                </div>
              </div>
            </details>
          ))
        }
      </div>
    </div>
  </div>
</section>
