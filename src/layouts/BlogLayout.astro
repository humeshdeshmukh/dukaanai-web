---
import BaseLayout from "./BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { Image } from "astro:assets";
import { site } from "../data/site";

interface Props {
  title: string;
  description: string;
  publishDate: string;
  author?: string;
  imagePath?: string;
  tags?: string[];
}

const { 
  title, 
  description, 
  publishDate, 
  author = "Dukaan AI Team", 
  imagePath,
  tags = []
} = Astro.props;

// Schema for the Article
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "author": {
    "@type": "Organization",
    "name": "Dukaan AI"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Dukaan AI",
    "logo": {
      "@type": "ImageObject",
      "url": `${site.url}/images/dukaan-logo.jpeg`
    }
  },
  "datePublished": publishDate,
  "image": imagePath ? `${site.url}${imagePath}` : `${site.url}/images/hero-overview.png`
};

const extraSchemas = [articleSchema];
---

<BaseLayout title={title} description={description} extraSchemas={extraSchemas}>
  <SiteHeader />
  
  <article class="pt-24 sm:pt-32 pb-20">
    <div class="section-shell max-w-4xl">
      <!-- Breadcrumbs & Meta -->
      <nav class="flex items-center gap-2 text-xs font-bold uppercase tracking-widest text-forest-900/40 mb-6">
        <a href="/blog" class="hover:text-gold-600 transition">Blog</a>
        <span>/</span>
        <span class="text-forest-900/60 truncate">{title}</span>
      </nav>

      <div class="space-y-6 mb-12">
        <div class="flex flex-wrap gap-2">
          {tags.map(tag => (
            <span class="inline-flex rounded-full bg-gold-100 px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-gold-700">
              {tag}
            </span>
          ))}
        </div>
        
        <h1 class="font-display text-4xl font-bold leading-[1.1] text-forest-950 sm:text-5xl lg:text-6xl">
          {title}
        </h1>
        
        <div class="flex items-center gap-4 text-sm text-forest-800/60">
          <time datetime={publishDate}>{new Date(publishDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
          <span class="h-1 w-1 rounded-full bg-forest-900/20"></span>
          <span>By {author}</span>
        </div>
      </div>

      <!-- Main Content -->
      <div class="prose prose-forest max-w-none">
        <div class="text-lg leading-9 text-forest-800 space-y-8">
           <slot />
        </div>
      </div>

      <!-- Footer CTA for the Blog -->
      <div class="mt-20 panel border-gold-300/30 bg-forest-50/50 p-8 sm:p-12 text-center">
        <h2 class="font-display text-2xl font-bold text-forest-950">Was this guide helpful?</h2>
        <p class="mt-4 text-forest-800">Learn more about how Dukaan AI can transform your kirana business.</p>
        <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href={site.playStoreUrl} class="inline-flex items-center justify-center rounded-full bg-forest-800 px-8 py-4 text-sm font-bold text-white shadow-lg transition hover:bg-forest-700">
            Download Dukaan AI
          </a>
          <a href="/#features" class="inline-flex items-center justify-center rounded-full border border-forest-900/10 bg-white px-8 py-4 text-sm font-bold text-forest-900 transition hover:border-gold-400">
            Explore Features
          </a>
        </div>
      </div>
    </div>
  </article>

  <SiteFooter />
</BaseLayout>

<style is:global>
  /* Custom prose-like styles for better typography in blog posts */
  .prose h2 {
    @apply font-display text-3xl font-bold text-forest-950 mt-12 mb-6;
  }
  .prose h3 {
    @apply font-display text-2xl font-bold text-forest-950 mt-10 mb-4;
  }
  .prose p {
    @apply mb-6;
  }
  .prose ul {
    @apply list-disc list-outside ml-6 mb-8 space-y-4;
  }
  .prose li {
    @apply pl-2;
  }
  .prose strong {
    @apply font-bold text-forest-950;
  }
  .prose blockquote {
    @apply border-l-4 border-gold-400 bg-forest-50/50 px-6 py-4 italic text-forest-900 my-10 rounded-r-2xl;
  }
</style>
