---
import BaseLayout from "./BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { Image } from "astro:assets";
import { site } from "../data/site";
import type { ImageMetadata } from "astro";

import { Sparkles } from "@lucide/astro";

interface Props {
  title: string;
  description: string;
  featureTitle: string;
  featureDescription: string;
  imagePath: string;
  badge: string;
  benefits?: { title: string; text: string }[];
  faqs?: { question: string; answer: string }[];
}

const {
  title,
  description,
  featureTitle,
  featureDescription,
  imagePath,
  badge,
  benefits = [],
  faqs = []
} = Astro.props;

// Import all images from assets for internal processing
const allImages = import.meta.glob<{ default: ImageMetadata }>("/src/assets/images/*.{jpeg,jpg,png,gif}");
const assetPath = `/src/assets${imagePath}`;
const featureImage = allImages[assetPath];
---

<BaseLayout title={title} description={description}>
  <SiteHeader />
  
  <main class="pt-20 sm:pt-28">
    <!-- Feature Hero -->
    <section class="section-shell pb-14 sm:pb-24">
      <div class="relative overflow-hidden rounded-[42px] border border-white/55 bg-[radial-gradient(circle_at_top_left,_rgba(245,219,148,0.22),_transparent_24%),linear-gradient(135deg,_#fffdf7_0%,_#f1f5ec_46%,_#e5efe5_100%)] px-6 py-8 shadow-[0_34px_120px_rgba(13,41,26,0.12)] sm:px-10 sm:py-12 lg:px-14 lg:py-16">
        <div class="grid-overlay absolute inset-0 opacity-[0.03]"></div>
        <div class="pointer-events-none absolute -left-20 -top-20 h-80 w-80 rounded-full bg-gold-200/35 blur-3xl"></div>
        <div class="pointer-events-none absolute -bottom-20 -right-20 h-96 w-96 rounded-full bg-forest-200/30 blur-3xl"></div>

        <div class="relative grid gap-12 lg:grid-cols-2 lg:items-center">
          <div class="space-y-8">
            <div class="inline-flex items-center gap-2 rounded-full border border-gold-300/70 bg-white/80 px-4 py-2 text-[10px] font-bold uppercase tracking-[0.24em] text-forest-800 shadow-sm">
              <Sparkles size={12} class="text-gold-500" />
              {badge}
            </div>
            <h1 class="font-display text-[clamp(2.5rem,6vw,4.5rem)] font-bold leading-[1] tracking-tight text-forest-950">
              {featureTitle}
            </h1>
            <p class="max-w-xl text-lg leading-8 text-forest-800 sm:text-xl">
              {featureDescription}
            </p>
            <div class="flex flex-col gap-4 sm:flex-row">
              <a href={site.playStoreUrl} target="_blank" rel="noreferrer" class="inline-flex items-center justify-center rounded-full bg-forest-800 px-10 py-4 text-sm font-bold text-white shadow-glow transition hover:-translate-y-0.5 hover:bg-forest-700">
                Download App on Android
              </a>
            </div>
          </div>
          
          <div class="relative mx-auto w-full max-w-sm lg:max-w-none">
            <div class="rounded-[48px] border border-white/50 bg-white p-3 shadow-2xl ring-1 ring-forest-950/5">
              <div class="aspect-[4/5] overflow-hidden rounded-[38px] bg-forest-50/50">
                {featureImage ? (
                  <Image 
                    src={featureImage()} 
                    alt={`${featureTitle} - Dukaan AI feature preview`} 
                    width={800} 
                    height={1000} 
                    class="h-full w-full object-cover object-top" 
                    loading="eager"
                  />
                ) : (
                  <img src={imagePath} alt={featureTitle} class="h-full w-full object-cover object-top" />
                )}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Detailed Benefits -->
    {benefits.length > 0 && (
      <section class="bg-forest-50/40 py-16 sm:py-24">
        <div class="section-shell">
          <div class="mb-14 max-w-2xl">
            <span class="eyebrow border-forest-900/10 bg-white text-forest-800">How it helps</span>
            <h2 class="mt-6 font-display text-4xl font-bold text-forest-950 sm:text-5xl">
              Powerful tools for your business growth
            </h2>
          </div>
          <div class="grid gap-6 md:grid-cols-2">
            {benefits.map((benefit) => (
              <div class="group panel border-forest-900/5 bg-white p-8 transition-all hover:-translate-y-1 hover:border-gold-400 hover:shadow-xl">
                <h3 class="font-display text-2xl font-bold text-forest-900 group-hover:text-gold-600 transition-colors uppercase tracking-tight">{benefit.title}</h3>
                <p class="mt-4 text-base leading-8 text-forest-800/80">{benefit.text}</p>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- FAQ Section -->
    {faqs.length > 0 && (
      <section class="section-shell py-16 sm:py-24">
        <div class="max-w-3xl">
          <span class="eyebrow">Expert answers</span>
          <h2 class="mt-4 font-display text-4xl font-bold text-forest-950">
            Frequently asked questions
          </h2>
          <div class="mt-10 grid gap-4">
            {faqs.map((faq) => (
              <details class="accordion-card">
                <summary class="accordion-summary">
                  <h3 class="pr-4 text-lg font-bold text-forest-950">{faq.question}</h3>
                  <span class="accordion-plus"></span>
                </summary>
                <div class="accordion-body">
                  <div class="accordion-body-inner">
                    <p class="text-sm leading-7 text-forest-800">{faq.answer}</p>
                  </div>
                </div>
              </details>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Final CTA — Light Mode Re-design -->
    <section class="section-shell pb-24 pt-10">
      <div class="relative overflow-hidden rounded-[42px] border border-white/55 bg-[radial-gradient(circle_at_bottom_right,_rgba(245,219,148,0.22),_transparent_24%),linear-gradient(135deg,_#fffdf7_0%,_#f1f5ec_46%,_#e5efe5_100%)] px-6 py-16 text-center shadow-[0_34px_120px_rgba(13,41,26,0.12)] sm:py-24">
        <div class="grid-overlay absolute inset-0 opacity-[0.03]"></div>
        <div class="pointer-events-none absolute -bottom-20 -right-20 h-64 w-64 rounded-full bg-gold-400/20 blur-3xl"></div>
        <div class="pointer-events-none absolute -left-10 -top-10 h-72 w-72 rounded-full bg-forest-200/20 blur-3xl"></div>
        
        <div class="relative z-10 mx-auto max-w-3xl">
          <p class="mb-4 text-xs font-bold uppercase tracking-[0.3em] text-forest-600">Start today</p>
          <h2 class="font-display text-4xl font-bold leading-tight text-forest-950 sm:text-5xl lg:text-6xl">
            Ready to simplify your shop management?
          </h2>
          <p class="mx-auto mt-6 max-w-xl text-lg text-forest-800/80 sm:text-xl">
            Join thousands of Indian shopkeepers using Dukaan AI to manage their business smarter.
          </p>
          <div class="mt-12">
            <a href={site.playStoreUrl} target="_blank" rel="noreferrer" class="inline-flex items-center justify-center rounded-full bg-forest-800 px-12 py-5 text-base font-bold text-white shadow-glow transition hover:-translate-y-1 hover:bg-forest-700">
              Download Dukaan AI App
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
