---
import { site } from "../data/site";
import "../styles/global.css";
import heroPremium from "../assets/images/hero-premium.jpeg";
import { getLangFromUrl } from "../i18n/utils";

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  extraSchemas?: any[];
  faqs?: { question: string, answer: string }[];
}

const {
  title = site.title,
  description = site.description,
  noindex = false,
  extraSchemas = [],
  faqs = []
} = Astro.props;

const lang = getLangFromUrl(Astro.url);

const canonical = new URL(Astro.url.pathname, site.url).toString();
const robotsContent = noindex
  ? "noindex, nofollow"
  : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";
const breadcrumbSchema = Astro.url.pathname !== "/" ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": site.url
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": title.split("|")[0].trim(),
      "item": new URL(Astro.url.pathname, site.url).toString()
    }
  ]
} : null;

const pageSchemas = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    name: site.name,
    alternateName: site.alternateName,
    url: site.url,
    logo: `${site.url}/images/dukaan-logo.jpeg`,
    email: site.businessEmail,
    sameAs: Object.values(site.socialLinks),
    contactPoint: {
      "@type": "ContactPoint",
      "contactType": "Customer Support",
      "availableLanguage": ["Hindi", "English", "Marathi", "Gujarati"]
    },
    areaServed: {
      "@type": "Country",
      "name": "India"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: site.name,
    url: site.url,
    inLanguage: lang,
    description: site.description
  },
  {
    "@context": "https://schema.org",
    "@type": "MobileApplication",
    name: site.name,
    alternateName: site.alternateName,
    applicationCategory: site.category,
    applicationSubCategory: site.subCategory,
    operatingSystem: "Android",
    description: site.description,
    applicationId: site.playStoreId,
    softwareVersion: site.version,
    offers: {
      "@type": "Offer",
      price: "0",
      priceCurrency: "INR",
      availability: "https://schema.org/InStock"
    },
    url: site.url,
    image: `${site.url}${site.socialImage}`,
    downloadUrl: site.playStoreUrl,
    installUrl: site.playStoreUrl,
    aggregateRating: {
      "@type": "AggregateRating",
      ratingValue: site.ratingValue,
      ratingCount: site.ratingCount,
      bestRating: "5",
      worstRating: "1"
    },
    featureList: [
      "Voice Billing in 24 Indian Languages",
      "Digital Khata and Udhaar Management",
      "GST Invoice Generation",
      "AI Bill Scanner",
      "Offline Mode - Works without internet",
      "WhatsApp Payment Reminders",
      "Inventory Tracking",
      "Business Reports and Analytics",
      "Hindi and Regional Language Support",
      "Bank-level Data Encryption"
    ],
    screenshot: [
      `${site.url}/images/screenshot-1.png`,
      `${site.url}/images/screenshot-2.png`,
      `${site.url}/images/screenshot-3.png`
    ],
    publisher: {
      "@type": "Organization",
      name: site.name,
      email: site.businessEmail,
      url: site.url
    }
  }
];

if (faqs && faqs.length > 0) {
  pageSchemas.push({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(item => ({
      "@type": "Question",
      "name": item.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.answer
      }
    }))
  } as any);
}

if (extraSchemas.length > 0) {
  pageSchemas.push(...extraSchemas);
}

if (breadcrumbSchema) {
  pageSchemas.push(breadcrumbSchema as any);
}

import { ui, languageCodes } from "../i18n/ui";

const supportedLangs = languageCodes;

const getAlternateUrl = (l: string) => {
  const pathname = Astro.url.pathname;
  const currentLang = getLangFromUrl(Astro.url);
  
  let pathWithoutLang = pathname;
  if (currentLang !== 'en') {
    pathWithoutLang = pathname.substring(currentLang.length + 1) || "/";
  }
  
  const baseUrl = site.url.endsWith("/") ? site.url.slice(0, -1) : site.url;
  const cleanPath = pathWithoutLang.startsWith("/") ? pathWithoutLang : `/${pathWithoutLang}`;
  
  if (l === "en") return `${baseUrl}${cleanPath}`;
  return `${baseUrl}/${l}${cleanPath}`;
};

const alternates = supportedLangs
  .filter(l => l !== 'hinglish')
  .map(l => ({
    lang: l,
    url: getAlternateUrl(l)
  }));
---

<!doctype html>
<html lang={lang}>
  <head>
    <!-- Google tag (gtag.js) -->
    <script is:inline type="text/partytown" async src="https://www.googletagmanager.com/gtag/js?id=G-NML2GE0WKG"></script>
    <script is:inline type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-NML2GE0WKG');
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="google-site-verification" content="KJNICerwlN2jwmF2dnkqZCdUA8CCq5_OEp_pF2ZWR3g" />
    <meta name="msvalidate.01" content="EC0850B81FA4EB0505CA4C9900D49D02" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={site.keywords.join(", ")} />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />
    
    {alternates.map(alt => (
      <link rel="alternate" hreflang={alt.lang} href={alt.url} />
    ))}
    <link rel="alternate" hreflang="x-default" href={getAlternateUrl("en")} />
    <meta name="application-name" content={site.name} />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content={site.shortName} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content={site.themeColor} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/jpeg" href="/images/dukaan-logo.jpeg" />
    <link rel="apple-touch-icon" href="/images/dukaan-logo.jpeg" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/cormorant-700.woff2" crossorigin fetchpriority="high" />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/manrope-400.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/manrope-700.woff2" crossorigin />

    <style is:global>
      /* Manrope Font Family */
      @font-face {
        font-family: "Manrope";
        src: url("/fonts/manrope-400.woff2") format("woff2");
        font-weight: 400;
        font-style: normal;
        font-display: optional;
      }
      @font-face {
        font-family: "Manrope";
        src: url("/fonts/manrope-400.woff2") format("woff2");
        font-weight: 500;
        font-style: normal;
        font-display: optional;
      }
      @font-face {
        font-family: "Manrope";
        src: url("/fonts/manrope-700.woff2") format("woff2");
        font-weight: 600;
        font-style: normal;
        font-display: optional;
      }
      @font-face {
        font-family: "Manrope";
        src: url("/fonts/manrope-700.woff2") format("woff2");
        font-weight: 700;
        font-style: normal;
        font-display: optional;
      }
      @font-face {
        font-family: "Manrope";
        src: url("/fonts/manrope-700.woff2") format("woff2");
        font-weight: 800;
        font-style: normal;
        font-display: optional;
      }

      /* Cormorant Garamond Font Family */
      @font-face {
        font-family: "Cormorant Garamond";
        src: url("/fonts/cormorant-600.woff2") format("woff2");
        font-weight: 600;
        font-style: normal;
        font-display: optional;
      }
      @font-face {
        font-family: "Cormorant Garamond";
        src: url("/fonts/cormorant-700.woff2") format("woff2");
        font-weight: 700;
        font-style: normal;
        font-display: optional;
      }
    </style>

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${site.url}${site.socialImage}`} />
    <meta property="og:image:alt" content="Dukaan AI retail management app preview" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${site.url}${site.socialImage}`} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(pageSchemas)} />
    
    <script is:inline define:vars={{ languageCodes }}>
      // Smart Language Detection & Redirection
      (function() {
        // Only redirect on the root path
        if (window.location.pathname !== '/' && window.location.pathname !== '') return;
        
        // Don't redirect if we've already redirected or the user manually chose a path
        if (sessionStorage.getItem('ua-lang-redirected')) return;
        
        const supported = languageCodes;
        const userLang = (navigator.language || navigator.userLanguage).split('-')[0].toLowerCase();
        
        if (userLang !== 'en' && supported.includes(userLang)) {
          sessionStorage.setItem('ua-lang-redirected', 'true');
          window.location.href = '/' + userLang + '/';
        }
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
